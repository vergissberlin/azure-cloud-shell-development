#!/usr/bin/env bash
# cshell – Azure Cloud Shell development helper
# Subcommands: setup | hybrid | backup | restore

set -euo pipefail

SCRIPT_NAME="cshell"
SCRIPT_VERSION="1.2.0" # x-release-please-version
REPO_SLUG="vergissberlin/azure-cloud-shell-development"
DEFAULT_REF="main"
LATEST_RELEASE_API="https://api.github.com/repos/${REPO_SLUG}/releases/latest"
INSTALL_PATH_DEFAULT="/usr/bin/${SCRIPT_NAME}"
INSTALL_PATH_USER="${HOME}/.local/bin/${SCRIPT_NAME}"
UPDATE_INSTALL_PATH_DEFAULT="/usr/local/bin/${SCRIPT_NAME}"
ENV_FILE="${HOME}/.cshell.env"
ARCHIVE_FILE="${HOME}/archive.zip"
SCRIPT_SOURCE="${BASH_SOURCE[0]:-$0}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_SOURCE}")" && pwd)"
CLI_UTILS_PATH="${SCRIPT_DIR}/scripts/misc-cli-utils.sh"

CHART_REPO="oci://us-docker.pkg.dev/apigee-release/apigee-hybrid-helm-charts"
CHART_VERSION="1.16.0-hotfix.1"
APIGEE_CHARTS=(
  apigee-operator
  apigee-datastore
  apigee-env
  apigee-ingress-manager
  apigee-org
  apigee-redis
  apigee-telemetry
  apigee-virtualhost
)
CSHELL_COMMANDS=(init setup hybrid backup restore)

DOC_BEFORE_BEGIN="https://docs.cloud.google.com/apigee/docs/hybrid/v1.16/install-before-begin"
DOC_DOWNLOAD_CHARTS="https://docs.cloud.google.com/apigee/docs/hybrid/v1.16/install-download-charts"
DOC_INSTALL_HYBRID="https://github.com/vergissberlin/apigee-hybride-development/blob/main/docs/install-apigee-hybrid.md"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

if [[ -f "${CLI_UTILS_PATH}" ]]; then
  # shellcheck source=/dev/null
  source "${CLI_UTILS_PATH}"
fi

# BEGIN_CLI_UTILS_FALLBACK
# Fallback for globally installed script where shared utils are unavailable.
if ! declare -F info >/dev/null 2>&1; then
  RESET='\033[0m'
  BLACK='\033[30m'
  CYAN='\033[36m'
  GREEN='\033[32m'
  YELLOW='\033[33m'
  RED='\033[31m'
  BG_CYAN='\033[46m'
  BG_GREEN='\033[42m'
  BG_YELLOW='\033[43m'
  BG_RED='\033[41m'
  CHECKMARK='✓'
  CROSS='✗'
  ARROW='→'

  box() { echo -e "${2:-$BG_CYAN}${3:-$BLACK} $1 ${RESET}"; }
  info() { echo -e "$(box 'INFO' "$BG_CYAN" "$BLACK") ${CYAN}$*${RESET}"; }
  success() { echo -e "$(box 'DONE' "$BG_GREEN" "$BLACK") ${GREEN}${CHECKMARK}${RESET} ${GREEN}$*${RESET}"; }
  warn() { echo -e "$(box 'WARN' "$BG_YELLOW" "$BLACK") ${YELLOW}$*${RESET}"; }
  error() { echo -e "$(box 'ERR' "$BG_RED" "$BLACK") ${RED}${CROSS}${RESET} ${RED}$*${RESET}" >&2; }
  section() {
    local title="$1"
    local desc="${2:-}"
    local color="${3:-cyan}"
    local tone="$CYAN"

    case "${color}" in
      green) tone="$GREEN" ;;
      yellow) tone="$YELLOW" ;;
      red) tone="$RED" ;;
      blue) tone="$CYAN" ;;
    esac

    echo
    echo -e "${tone}[${title}]${RESET} ${desc}"
  }
  bullet_list() { local line; for line in "$@"; do echo -e "  ${ARROW} ${line}"; done; }
fi
# END_CLI_UTILS_FALLBACK

ask() {
  local prompt="$1"
  local default="${2:-}"
  local value
  if [[ -n "$default" ]]; then
    read -rp "${prompt} [${default}]: " value
    echo "${value:-$default}"
  else
    read -rp "${prompt}: " value
    echo "$value"
  fi
}

require_root() {
  if [[ $EUID -ne 0 ]]; then
    error "This step requires root privileges. Please run with sudo."
    exit 1
  fi
}

command_exists() {
  command -v "$1" &>/dev/null
}

append_line_if_missing() {
  local target_file="$1"
  local line="$2"

  touch "${target_file}"
  if ! grep -Fqx "${line}" "${target_file}"; then
    echo "${line}" >> "${target_file}"
  fi
}

install_bash_completion() {
  local bash_completion_dir="${HOME}/.local/share/bash-completion/completions"
  local bash_completion_file="${bash_completion_dir}/${SCRIPT_NAME}"
  local command_list="${CSHELL_COMMANDS[*]}"

  mkdir -p "${bash_completion_dir}"
  cat > "${bash_completion_file}" <<EOF
_${SCRIPT_NAME}_completions() {
  local cur
  COMPREPLY=()
  cur="\${COMP_WORDS[COMP_CWORD]}"
  COMPREPLY=(\$(compgen -W "${command_list}" -- "\${cur}"))
}
complete -F _${SCRIPT_NAME}_completions ${SCRIPT_NAME}
EOF
  success "Bash completion installed: ${bash_completion_file}"
}

install_zsh_completion() {
  local zsh_completion_dir="${HOME}/.zsh/completions"
  local zsh_completion_file="${zsh_completion_dir}/_${SCRIPT_NAME}"
  local zshrc_file="${HOME}/.zshrc"
  local command_list="${CSHELL_COMMANDS[*]}"

  mkdir -p "${zsh_completion_dir}"
  cat > "${zsh_completion_file}" <<EOF
#compdef ${SCRIPT_NAME}

local -a commands
commands=(${command_list})
_describe 'command' commands
EOF

  append_line_if_missing "${zshrc_file}" ""
  append_line_if_missing "${zshrc_file}" "# Added by cshell setup: user completion path"
  append_line_if_missing "${zshrc_file}" "fpath=(\"${zsh_completion_dir}\" \$fpath)"
  append_line_if_missing "${zshrc_file}" "autoload -Uz compinit"
  append_line_if_missing "${zshrc_file}" "compinit"

  success "Zsh completion installed: ${zsh_completion_file}"
  info "Restart zsh or run 'exec zsh' to load new completion immediately."
}

install_shell_completion() {
  local install_failed=0

  if command_exists bash; then
    if ! install_bash_completion; then
      warn "Could not install bash completion for ${SCRIPT_NAME}."
      install_failed=1
    fi
  else
    warn "bash not found. Skipping bash completion setup."
  fi

  if command_exists zsh; then
    if ! install_zsh_completion; then
      warn "Could not install zsh completion for ${SCRIPT_NAME}."
      install_failed=1
    fi
  else
    warn "zsh not found. Skipping zsh completion setup."
  fi

  if [[ ${install_failed} -eq 1 ]]; then
    warn "Completion setup finished with warnings."
  else
    success "Autocomplete setup completed for available shells."
  fi
}

is_azure_cloud_shell() {
  [[ -n "${ACC_CLOUD:-}" || -n "${AZURE_HTTP_USER_AGENT:-}" || -n "${CLOUD_SHELL:-}" ]]
}

resolve_latest_release_tag() {
  local latest_json latest_tag

  if ! command_exists curl; then
    return 1
  fi

  latest_json="$(curl -fsSL "${LATEST_RELEASE_API}" 2>/dev/null || true)"
  latest_tag="$(printf '%s' "${latest_json}" | sed -n 's/.*"tag_name":[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
  [[ -n "${latest_tag}" ]] || return 1
  printf '%s\n' "${latest_tag}"
}

is_newer_version() {
  local current_version="$1"
  local latest_version="$2"
  local highest_version

  if [[ -z "${current_version}" || -z "${latest_version}" || "${current_version}" == "${latest_version}" ]]; then
    return 1
  fi

  highest_version="$(printf '%s\n%s\n' "${current_version}" "${latest_version}" | sort -V | tail -n 1)"
  [[ "${highest_version}" == "${latest_version}" ]]
}

check_for_update_notice() {
  local latest_tag latest_version

  latest_tag="$(resolve_latest_release_tag || true)"
  [[ -n "${latest_tag}" ]] || return 0

  latest_version="${latest_tag#v}"
  if is_newer_version "${SCRIPT_VERSION}" "${latest_version}"; then
    warn "A newer ${SCRIPT_NAME} version is available (${latest_version}). Run '${SCRIPT_NAME} update'."
  fi
}

is_path_writable_for_replace() {
  local target_path="$1"
  local target_dir

  if [[ -e "${target_path}" ]]; then
    [[ -w "${target_path}" ]]
    return
  fi

  target_dir="$(dirname "${target_path}")"
  [[ -w "${target_dir}" ]]
}

resolve_update_target_path() {
  local current_path

  current_path="$(command -v "${SCRIPT_NAME}" 2>/dev/null || true)"
  if [[ -n "${current_path}" ]] && is_path_writable_for_replace "${current_path}"; then
    printf '%s\n' "${current_path}"
    return 0
  fi

  if is_path_writable_for_replace "${UPDATE_INSTALL_PATH_DEFAULT}"; then
    printf '%s\n' "${UPDATE_INSTALL_PATH_DEFAULT}"
    return 0
  fi

  mkdir -p "$(dirname "${INSTALL_PATH_USER}")"
  printf '%s\n' "${INSTALL_PATH_USER}"
}

should_run_update_notice() {
  local command_name="${1:-}"
  case "${command_name}" in
    init|setup|hybrid|backup|restore|update) return 0 ;;
    *) return 1 ;;
  esac
}

upload_blob_with_fallback() {
  local account_name="$1"
  local container_name="$2"
  local blob_name="$3"
  local file_path="$4"
  local cmd_output

  if cmd_output=$(az storage blob upload \
    --account-name "${account_name}" \
    --container-name "${container_name}" \
    --name "${blob_name}" \
    --file "${file_path}" \
    --auth-mode login \
    --only-show-errors 2>&1); then
    return 0
  fi

  warn "Upload with Azure AD login failed. Trying account key from ${ENV_FILE} ..."
  if [[ -n "${AZURE_STORAGE_ACCOUNT_KEY:-}" ]]; then
    if cmd_output=$(az storage blob upload \
      --account-name "${account_name}" \
      --container-name "${container_name}" \
      --name "${blob_name}" \
      --file "${file_path}" \
      --auth-mode key \
      --account-key "${AZURE_STORAGE_ACCOUNT_KEY}" \
      --only-show-errors 2>&1); then
      return 0
    fi
    warn "Upload with account key also failed."
    warn "${cmd_output}"
    return 1
  fi

  warn "${cmd_output}"
  warn "No AZURE_STORAGE_ACCOUNT_KEY set in ${ENV_FILE}."
  return 1
}

download_blob_with_fallback() {
  local account_name="$1"
  local container_name="$2"
  local blob_name="$3"
  local file_path="$4"
  local cmd_output

  if cmd_output=$(az storage blob download \
    --account-name "${account_name}" \
    --container-name "${container_name}" \
    --name "${blob_name}" \
    --file "${file_path}" \
    --auth-mode login \
    --only-show-errors 2>&1); then
    return 0
  fi

  warn "Download with Azure AD login failed. Trying account key from ${ENV_FILE} ..."
  if [[ -n "${AZURE_STORAGE_ACCOUNT_KEY:-}" ]]; then
    if cmd_output=$(az storage blob download \
      --account-name "${account_name}" \
      --container-name "${container_name}" \
      --name "${blob_name}" \
      --file "${file_path}" \
      --auth-mode key \
      --account-key "${AZURE_STORAGE_ACCOUNT_KEY}" \
      --only-show-errors 2>&1); then
      return 0
    fi
    warn "Download with account key also failed."
    warn "${cmd_output}"
    return 1
  fi

  warn "${cmd_output}"
  warn "No AZURE_STORAGE_ACCOUNT_KEY set in ${ENV_FILE}."
  return 1
}

# ---------------------------------------------------------------------------
# setup
# ---------------------------------------------------------------------------

cmd_setup() {
  section "SETUP" "cshell setup workflow" "cyan"

  # ── 1. Install cshell binary ──────────────────────────────────────────────
  local install_path
  if is_azure_cloud_shell; then
    info "Azure Cloud Shell detected. Using user-space install defaults."
  fi

  if [[ $EUID -eq 0 ]]; then
    install_path="${INSTALL_PATH_DEFAULT}"
  else
    install_path="${INSTALL_PATH_USER}"
    mkdir -p "$(dirname "${install_path}")"
  fi

  info "Installing ${SCRIPT_NAME} to ${install_path} ..."
  cp "$(realpath "$0")" "${install_path}"
  chmod +x "${install_path}"
  success "cshell installed to ${install_path}"
  if [[ "${install_path}" == "${INSTALL_PATH_USER}" ]]; then
    if [[ ":${PATH}:" != *":${HOME}/.local/bin:"* ]]; then
      warn "${HOME}/.local/bin is not in PATH. Add this to your shell profile:"
      echo '  export PATH="$HOME/.local/bin:$PATH"'
    fi
  fi

  # ── 2. Configure shell completion ─────────────────────────────────────────
  section "AUTOCOMPLETE" "Install command completion for cshell" "cyan"
  install_shell_completion || warn "Autocomplete setup encountered an unexpected issue."

  # ── 3. Install gcloud CLI (Apigee hybrid development) ────────────────────
  if command_exists gcloud; then
    success "gcloud is already installed ($(gcloud --version 2>&1 | head -1))"
  else
    info "Installing Google Cloud SDK ..."
    if command_exists apt-get && [[ $EUID -eq 0 ]]; then
      apt-get update -qq
      apt-get install -y ca-certificates gnupg curl
      echo "deb [signed-by=/usr/share/keyrings/cloud.google.gpg] \
https://packages.cloud.google.com/apt cloud-sdk main" \
        | tee /etc/apt/sources.list.d/google-cloud-sdk.list
      curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg \
        | gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg
      apt-get update -qq
      apt-get install -y google-cloud-cli
    elif command_exists brew; then
      brew install --cask google-cloud-sdk
    else
      info "No apt/brew found. Using official tarball installer ..."
      local tmp_dir gcloud_tar gcloud_root gcloud_bin target_bin os arch
      tmp_dir="$(mktemp -d)"
      os="$(uname -s | tr '[:upper:]' '[:lower:]')"
      arch="$(uname -m)"
      case "${arch}" in
        x86_64|amd64) arch="x86_64" ;;
        aarch64|arm64) arch="arm" ;;
        *)
          error "Unsupported architecture for gcloud installer: ${arch}"
          exit 1
          ;;
      esac
      gcloud_tar="${tmp_dir}/google-cloud-cli.tar.gz"
      curl -fsSL "https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-cli-${os}-${arch}.tar.gz" -o "${gcloud_tar}"
      tar -xzf "${gcloud_tar}" -C "${tmp_dir}"
      gcloud_root="${tmp_dir}/google-cloud-sdk"
      "${gcloud_root}/install.sh" --quiet --path-update=true --usage-reporting=false --command-completion=true
      gcloud_bin="${gcloud_root}/bin/gcloud"
      if [[ -x "${gcloud_bin}" ]]; then
        if [[ $EUID -eq 0 ]]; then
          target_bin="/usr/local/bin/gcloud"
        else
          mkdir -p "${HOME}/.local/bin"
          target_bin="${HOME}/.local/bin/gcloud"
        fi
        cp "${gcloud_bin}" "${target_bin}"
        chmod +x "${target_bin}"
      else
        error "gcloud binary not found after installer run."
        exit 1
      fi
    fi
    success "gcloud installed"
  fi

  # ── 4. Install oh-my-zsh ─────────────────────────────────────────────────
  if [[ -d "${HOME}/.oh-my-zsh" ]]; then
    success "oh-my-zsh is already installed"
  else
    info "Installing oh-my-zsh ..."
    if ! command_exists zsh; then
      if command_exists apt-get && [[ $EUID -eq 0 ]]; then
        apt-get install -y zsh
      elif command_exists brew; then
        brew install zsh
      elif command_exists dnf && [[ $EUID -eq 0 ]]; then
        dnf install -y zsh
      elif command_exists yum && [[ $EUID -eq 0 ]]; then
        yum install -y zsh
      elif command_exists apk && [[ $EUID -eq 0 ]]; then
        apk add zsh
      elif command_exists pacman && [[ $EUID -eq 0 ]]; then
        pacman -S --noconfirm zsh
      else
        error "zsh not found. Non-root environment detected and no user-space zsh installer is configured."
        info "Install zsh manually or run setup with elevated privileges in a writable system environment."
        exit 1
      fi
    fi
    RUNZSH=no CHSH=no \
      sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
    success "oh-my-zsh installed"
  fi

  # ── 5. Interactive storage-account setup ─────────────────────────────────
  section "AZURE STORAGE" "Backup configuration" "blue"
  local storage_account container_name storage_account_key

  storage_account=$(ask "Azure Storage Account name")
  container_name=$(ask "Azure Blob Container name" "backups")
  storage_account_key=$(ask "Azure Storage Account key (optional; enables upload fallback without RBAC role)" "${AZURE_STORAGE_ACCOUNT_KEY:-}")

  {
    echo "AZURE_STORAGE_ACCOUNT=${storage_account}"
    echo "AZURE_STORAGE_CONTAINER=${container_name}"
    if [[ -n "${storage_account_key}" ]]; then
      echo "AZURE_STORAGE_ACCOUNT_KEY=${storage_account_key}"
    fi
  } >> "${ENV_FILE}"

  success "Storage config saved to ${ENV_FILE}"
  info "Upload command that will be used during backup:"
  bullet_list \
    "az storage blob upload \\" \
    "--account-name ${storage_account} \\" \
    "--container-name ${container_name} \\" \
    "--name archive.zip \\" \
    "--file ${ARCHIVE_FILE}"
}

# ---------------------------------------------------------------------------
# hybrid
# ---------------------------------------------------------------------------

cmd_hybrid() {
  section "HYBRID" "Apigee Hybrid v1.16 setup" "cyan"

  # ── Documentation links ──────────────────────────────────────────────────
  info "Relevant documentation:"
  bullet_list \
    "Before you begin: ${DOC_BEFORE_BEGIN}" \
    "Download charts: ${DOC_DOWNLOAD_CHARTS}" \
    "Install guide: ${DOC_INSTALL_HYBRID}"

  # ── 1. Interactive environment variables ─────────────────────────────────
  section "ENV" "Apigee Hybrid environment variables" "blue"
  info "Values will be written to ${ENV_FILE}"

  # Load existing values if present
  if [[ -f "${ENV_FILE}" ]]; then
    # shellcheck source=/dev/null
    source "${ENV_FILE}"
  fi

  local project_id org_name org_display_name org_description \
        analytics_region runtime_type helm_charts_home \
        cluster_name cluster_region

  project_id=$(ask        "GCP Project ID"                           "${PROJECT_ID:-}")
  org_name=$(ask          "Apigee Organization name"                 "${ORG_NAME:-$project_id}")
  org_display_name=$(ask  "Apigee Organization display name"         "${ORG_DISPLAY_NAME:-$org_name}")
  org_description=$(ask   "Apigee Organization description"          "${ORGANIZATION_DESCRIPTION:-Apigee Hybrid organization}")
  analytics_region=$(ask  "Analytics region (e.g. europe-west1)"    "${ANALYTICS_REGION:-us-central1}")
  runtime_type=$(ask      "Runtime type"                             "${RUNTIMETYPE:-HYBRID}")
  cluster_name=$(ask      "Kubernetes cluster name"                  "${CLUSTER_NAME:-apigee-hybrid}")
  cluster_region=$(ask    "Kubernetes cluster region"                "${CLUSTER_REGION:-${analytics_region}}")
  helm_charts_home=$(ask  "Local Helm charts directory"              "${APIGEE_HELM_CHARTS_HOME:-${HOME}/apigee-hybrid/helm-charts}")

  # Preserve any existing Azure storage config before overwriting the file
  local azure_storage_account="${AZURE_STORAGE_ACCOUNT:-}"
  local azure_storage_container="${AZURE_STORAGE_CONTAINER:-}"
  local azure_storage_account_key="${AZURE_STORAGE_ACCOUNT_KEY:-}"

  # Persist to .env
  cat > "${ENV_FILE}" <<EOF
# Apigee Hybrid – environment variables
# Generated by cshell on $(date -u +"%Y-%m-%dT%H:%M:%SZ")

PROJECT_ID=${project_id}
ORG_NAME=${org_name}
ORG_DISPLAY_NAME=${org_display_name}
ORGANIZATION_DESCRIPTION=${org_description}
ANALYTICS_REGION=${analytics_region}
RUNTIMETYPE=${runtime_type}
CLUSTER_NAME=${cluster_name}
CLUSTER_REGION=${cluster_region}
APIGEE_HELM_CHARTS_HOME=${helm_charts_home}

# Helm chart coordinates
CHART_REPO=${CHART_REPO}
CHART_VERSION=${CHART_VERSION}
EOF

  # Re-append Azure storage config if it was saved previously
  if [[ -n "${azure_storage_account}" ]]; then
    {
      echo ""
      echo "# Azure Blob Storage (preserved from previous setup)"
      echo "AZURE_STORAGE_ACCOUNT=${azure_storage_account}"
      echo "AZURE_STORAGE_CONTAINER=${azure_storage_container}"
      if [[ -n "${azure_storage_account_key}" ]]; then
        echo "AZURE_STORAGE_ACCOUNT_KEY=${azure_storage_account_key}"
      fi
    } >> "${ENV_FILE}"
  fi

  success "Environment variables written to ${ENV_FILE}"
  echo    "Source them with:  source ${ENV_FILE}"
  echo ""

  # ── 2. Download Helm charts ───────────────────────────────────────────────
  if ! command_exists helm; then
    error "helm is not installed. Install Helm v3.14+ from https://helm.sh/docs/intro/install/"
    exit 1
  fi

  info "Downloading Apigee Hybrid Helm charts (version ${CHART_VERSION}) ..."
  mkdir -p "${helm_charts_home}"
  (
    cd "${helm_charts_home}"
    for chart in "${APIGEE_CHARTS[@]}"; do
      info "Pulling ${chart} ..."
      helm pull "${CHART_REPO}/${chart}" --version "${CHART_VERSION}" --untar
    done
  )
  success "Helm charts downloaded to ${helm_charts_home}"
}

# ---------------------------------------------------------------------------
# init – create Azure Storage Account and container
# ---------------------------------------------------------------------------

cmd_init() {
  section "INIT" "Create Azure Storage Account resources" "cyan"

  if ! command_exists az; then
    error "Azure CLI (az) is not installed or not in PATH."
    exit 1
  fi

  # Load existing env values as defaults (if available)
  if [[ -f "${ENV_FILE}" ]]; then
    # shellcheck source=/dev/null
    source "${ENV_FILE}"
  fi

  local subscription resource_group location storage_account container_name sku access_tier allow_cross_tenant_replication storage_account_key

  subscription=$(ask    "Azure Subscription ID or name (leave blank to use current)" "${AZURE_SUBSCRIPTION:-}")
  resource_group=$(ask  "Resource group name"                                         "${AZURE_RESOURCE_GROUP:-rg-cshell}")
  location=$(ask        "Azure region (e.g. germanywestcentral)"                       "${AZURE_LOCATION:-germanywestcentral}")
  storage_account=$(ask "Storage Account name (3-24 lowercase letters/digits)"        "${AZURE_STORAGE_ACCOUNT:-}")
  container_name=$(ask  "Blob container name"                                         "${AZURE_STORAGE_CONTAINER:-backups}")
  sku=$(ask             "Storage SKU (cheap default: Standard_LRS)"                   "${AZURE_STORAGE_SKU:-Standard_LRS}")
  access_tier=$(ask     "Storage access tier (Hot/Cool, cheap default: Cool)"         "${AZURE_STORAGE_ACCESS_TIER:-Cool}")
  allow_cross_tenant_replication=$(ask "Allow cross-tenant replication? (true/false)" "${AZURE_STORAGE_ALLOW_CROSS_TENANT_REPLICATION:-false}")

  # ── Set subscription ────────────────────────────────────────────────────
  if [[ -n "${subscription}" ]]; then
    info "Setting active subscription to '${subscription}' ..."
    az account set --subscription "${subscription}"
    success "Subscription set"
  fi

  # ── Create resource group if it does not exist ───────────────────────────
  if az group show --name "${resource_group}" &>/dev/null; then
    success "Resource group '${resource_group}' already exists"
  else
    info "Creating resource group '${resource_group}' in '${location}' ..."
    az group create \
      --name "${resource_group}" \
      --location "${location}" \
      --output none
    success "Resource group '${resource_group}' created"
  fi

  # ── Create Storage Account if it does not exist ──────────────────────────
  if az storage account show \
       --name "${storage_account}" \
       --resource-group "${resource_group}" &>/dev/null; then
    success "Storage Account '${storage_account}' already exists"
  else
    info "Creating Storage Account '${storage_account}' (${sku}, accessTier=${access_tier}, allowCrossTenantReplication=${allow_cross_tenant_replication}) ..."
    az storage account create \
      --name "${storage_account}" \
      --resource-group "${resource_group}" \
      --location "${location}" \
      --sku "${sku}" \
      --access-tier "${access_tier}" \
      --kind StorageV2 \
      --allow-cross-tenant-replication "${allow_cross_tenant_replication}" \
      --output none
    success "Storage Account '${storage_account}' created"
  fi

  # ── Create Blob container if it does not exist ───────────────────────────
  if az storage container exists \
       --name "${container_name}" \
       --account-name "${storage_account}" \
       --auth-mode login \
       --query "exists" \
       --output tsv 2>/dev/null | grep -q "^true$"; then
    success "Blob container '${container_name}' already exists"
  else
    info "Creating blob container '${container_name}' ..."
    az storage container create \
      --name "${container_name}" \
      --account-name "${storage_account}" \
      --auth-mode login \
      --output none
    success "Blob container '${container_name}' created"
  fi

  # ── Try to resolve account key for auth fallback ───────────────────────────
  storage_account_key="${AZURE_STORAGE_ACCOUNT_KEY:-}"
  if [[ -z "${storage_account_key}" ]]; then
    info "Trying to resolve storage account key for fallback auth ..."
    storage_account_key="$(
      az storage account keys list \
        --resource-group "${resource_group}" \
        --account-name "${storage_account}" \
        --query "[0].value" \
        --output tsv 2>/dev/null || true
    )"
    if [[ -n "${storage_account_key}" ]]; then
      success "Storage account key resolved and will be saved to ${ENV_FILE}"
    else
      warn "Could not resolve storage account key automatically."
      warn "You can set AZURE_STORAGE_ACCOUNT_KEY manually in ${ENV_FILE}."
    fi
  fi

  # ── Persist config to env file (remove any previous cshell init block) ───
  if [[ -f "${ENV_FILE}" ]]; then
    # Strip previous block written by cshell init to avoid duplicate entries
    sed -i '/^# Azure Storage – written by cshell init/,/^AZURE_STORAGE_ALLOW_CROSS_TENANT_REPLICATION=/d' "${ENV_FILE}"
  fi

  {
    echo ""
    echo "# Azure Storage – written by cshell init on $(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    echo "AZURE_SUBSCRIPTION=${subscription}"
    echo "AZURE_RESOURCE_GROUP=${resource_group}"
    echo "AZURE_LOCATION=${location}"
    echo "AZURE_STORAGE_ACCOUNT=${storage_account}"
    echo "AZURE_STORAGE_CONTAINER=${container_name}"
    if [[ -n "${storage_account_key}" ]]; then
      echo "AZURE_STORAGE_ACCOUNT_KEY=${storage_account_key}"
    fi
    echo "AZURE_STORAGE_SKU=${sku}"
    echo "AZURE_STORAGE_ACCESS_TIER=${access_tier}"
    echo "AZURE_STORAGE_ALLOW_CROSS_TENANT_REPLICATION=${allow_cross_tenant_replication}"
  } >> "${ENV_FILE}"

  success "Configuration saved to ${ENV_FILE}"
  info "Run 'cshell backup' to create and upload your first backup."
}

# ---------------------------------------------------------------------------
# backup
# ---------------------------------------------------------------------------

cmd_backup() {
  section "BACKUP" "Backup home directory" "cyan"

  info "Creating archive: ${ARCHIVE_FILE}"
  (cd "${HOME}" && zip -r "${ARCHIVE_FILE}" . \
    --exclude ".cache/*" \
    --exclude ".config/google-cloud-sdk/logs/*" \
    --exclude "archive.zip")
  success "Backup created: ${ARCHIVE_FILE}"

  # Optional: upload to Azure Blob Storage
  if [[ -f "${ENV_FILE}" ]]; then
    # shellcheck source=/dev/null
    source "${ENV_FILE}"
  fi

  if [[ -n "${AZURE_STORAGE_ACCOUNT:-}" && -n "${AZURE_STORAGE_CONTAINER:-}" ]]; then
    info "Uploading archive to Azure Blob Storage ..."
    if upload_blob_with_fallback \
      "${AZURE_STORAGE_ACCOUNT}" \
      "${AZURE_STORAGE_CONTAINER}" \
      "archive.zip" \
      "${ARCHIVE_FILE}"; then
      success "Archive uploaded to Azure Blob Storage"
      info "  Account  : ${AZURE_STORAGE_ACCOUNT}"
      info "  Container: ${AZURE_STORAGE_CONTAINER}"
    else
      warn "Backup archive exists locally but upload failed."
      warn "Grant one role like 'Storage Blob Data Contributor' on the storage account,"
      warn "or set AZURE_STORAGE_ACCOUNT_KEY in ${ENV_FILE} for key-based fallback."
    fi
  else
    warn "No Azure storage config found. Skipping upload."
    warn "Run 'cshell setup' to configure Azure Blob Storage."
  fi
}

# ---------------------------------------------------------------------------
# restore
# ---------------------------------------------------------------------------

cmd_restore() {
  section "RESTORE" "Restore home directory" "cyan"

  # Optionally download archive from Azure Blob Storage first
  if [[ -f "${ENV_FILE}" ]]; then
    # shellcheck source=/dev/null
    source "${ENV_FILE}"
  fi

  if [[ ! -f "${ARCHIVE_FILE}" ]]; then
    if [[ -n "${AZURE_STORAGE_ACCOUNT:-}" && -n "${AZURE_STORAGE_CONTAINER:-}" ]]; then
      info "Local archive not found. Downloading from Azure Blob Storage ..."
      if download_blob_with_fallback \
        "${AZURE_STORAGE_ACCOUNT}" \
        "${AZURE_STORAGE_CONTAINER}" \
        "archive.zip" \
        "${ARCHIVE_FILE}"; then
        success "Archive downloaded from Azure Blob Storage"
      else
        error "Could not download archive from Azure Blob Storage."
        error "Grant blob data permissions or set AZURE_STORAGE_ACCOUNT_KEY in ${ENV_FILE}."
        exit 1
      fi
    else
      error "Archive not found at ${ARCHIVE_FILE}, and no Azure storage config is available."
      warn "Place archive.zip in your home directory or run 'cshell setup' to configure Azure."
      exit 1
    fi
  fi

  info "Restoring from ${ARCHIVE_FILE} into ${HOME} ..."
  (cd "${HOME}" && unzip -o "${ARCHIVE_FILE}")
  success "Restore completed from ${ARCHIVE_FILE}"
}

cmd_update() {
  section "UPDATE" "Update ${SCRIPT_NAME} to latest release" "cyan"

  if ! command_exists curl; then
    error "curl is required for update but not installed."
    exit 1
  fi

  local latest_tag release_ref target_path target_dir raw_url tmp_file installed_version
  latest_tag="$(resolve_latest_release_tag || true)"
  release_ref="${latest_tag:-${DEFAULT_REF}}"
  raw_url="https://raw.githubusercontent.com/${REPO_SLUG}/${release_ref}/${SCRIPT_NAME}"
  target_path="$(resolve_update_target_path)"
  target_dir="$(dirname "${target_path}")"

  mkdir -p "${target_dir}"
  tmp_file="$(mktemp "${target_dir}/${SCRIPT_NAME}.XXXXXX")"

  if [[ -n "${latest_tag}" ]]; then
    info "Updating ${SCRIPT_NAME} to ${latest_tag} ..."
  else
    warn "Could not resolve latest release tag. Falling back to ${DEFAULT_REF}."
    info "Updating ${SCRIPT_NAME} from ${DEFAULT_REF} branch ..."
  fi

  info "Download source: ${raw_url}"
  if ! curl -fsSL "${raw_url}" -o "${tmp_file}"; then
    rm -f "${tmp_file}"
    error "Download failed. ${SCRIPT_NAME} was not changed."
    exit 1
  fi

  chmod +x "${tmp_file}"
  mv "${tmp_file}" "${target_path}"
  success "${SCRIPT_NAME} updated at ${target_path}"

  installed_version="$("${target_path}" --version 2>/dev/null || true)"
  if [[ -n "${installed_version}" ]]; then
    info "Installed version: ${installed_version}"
  else
    warn "Installed version could not be detected with '${target_path} --version'."
  fi
}

# ---------------------------------------------------------------------------
# usage / main
# ---------------------------------------------------------------------------

usage() {
  cat <<EOF
Usage: ${SCRIPT_NAME} <command>

Commands:
  init     Create Azure Resource Group, Storage Account and Blob container
  setup    Install cshell, gcloud, oh-my-zsh and configure Azure Blob Storage
  hybrid   Download Apigee Hybrid Helm charts and set up environment variables
  backup   Backup home directory to archive.zip (and upload to Azure)
  restore  Restore home directory from archive.zip (download from Azure if needed)
  update   Update cshell to latest release and print installed version

Environment file: ${ENV_FILE}
Autocomplete: installed automatically for bash/zsh during 'cshell setup'

Documentation:
  Apigee Hybrid before you begin : ${DOC_BEFORE_BEGIN}
  Apigee Hybrid download charts  : ${DOC_DOWNLOAD_CHARTS}
  Install guide                  : ${DOC_INSTALL_HYBRID}
EOF
}

main_cmd="${1:-}"
if should_run_update_notice "${main_cmd}"; then
  check_for_update_notice
fi

case "${main_cmd}" in
  --version|-v)
    echo "${SCRIPT_NAME} ${SCRIPT_VERSION}"
    ;;
  init)    cmd_init    ;;
  setup)   cmd_setup   ;;
  hybrid)  cmd_hybrid  ;;
  backup)  cmd_backup  ;;
  restore) cmd_restore ;;
  update)  cmd_update  ;;
  *)       usage; exit 1 ;;
esac
