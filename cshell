usage() {
	cat <<EOF
Usage: ${SCRIPT_NAME} [--no-update-check] <command> [args]

Global options:
  --no-update-check   Skip the GitHub version notice (also env CSHELL_NO_UPDATE_CHECK=1)
  NO_COLOR            When non-empty, disable ANSI colors (also when stdout is not a TTY)

Commands:
  init     Create Azure Resource Group, Storage Account and Blob container
  setup    Install cshell, gcloud and configure Azure Blob Storage
  hybrid   Hybrid env + chart pull; flags: --check [--strict] [--json], --export [--print], --step <1-13>, or interactive
  backup   Backup home directory to archive.zip (and upload to Azure) [--dry-run|-n] [--verbose|-v]
  restore  Restore home directory from archive.zip (download from Azure if needed) [--dry-run|-n] [--verbose|-v]
  update   Update cshell to latest release and print installed version (tarball+SHA256 when available)
  config   Inspect or change ${ENV_FILE} (show | set | validate)
  docs     Print project and Apigee documentation links

Exit codes:
  0  Success
  1  Error (missing env file, validation failure, unknown command, etc.)
  hybrid --check: exit 1 if ${ENV_FILE} is missing/empty, required Hybrid vars are missing/empty, or (with
      --strict) any checklist row is ${HYBRID_CHK_FAIL}. Rows marked ${HYBRID_CHK_SKIP} do not fail --strict. Without --strict, checklist
      rows are informational for exit status except required-variable errors above.
  Top-level -v is short for --version; backup/restore use -v for --verbose (see their help text).

Environment file: ${ENV_FILE} (use "${SCRIPT_NAME} config show" — avoid sourcing unless you trust every line)
Autocomplete: installed automatically for bash during 'cshell setup'

Documentation:
  Project README                 : ${DOC_PROJECT_README}
  Releases                       : ${DOC_PROJECT_RELEASES}
  Issues                         : ${DOC_PROJECT_ISSUES}
  Contributing                   : ${DOC_PROJECT_CONTRIBUTING}
  Apigee Hybrid before you begin : ${DOC_BEFORE_BEGIN}
  Apigee Hybrid download charts  : ${DOC_DOWNLOAD_CHARTS}
  Install guide                  : ${DOC_INSTALL_HYBRID}
  Google Hybrid v1.16 all steps  : run '${SCRIPT_NAME} docs'
EOF
}

CSHELL_NO_UPDATE_CHECK="${CSHELL_NO_UPDATE_CHECK:-0}"
_main_rest=()
while (($#)); do
	case "$1" in
		--no-update-check)
			CSHELL_NO_UPDATE_CHECK=1
			shift
			;;
		*)
			_main_rest+=("$1")
			shift
			;;
	esac
done
if ((${#_main_rest[@]} > 0)); then
	set -- "${_main_rest[@]}"
else
	set --
fi
unset _main_rest

main_cmd="${1:-}"
if should_run_update_notice "${main_cmd}"; then
	check_for_update_notice
fi

case "${main_cmd}" in
	--version | -v)
		echo "${SCRIPT_NAME} ${SCRIPT_VERSION}"
		;;
	init)
		shift
		cmd_init "$@"
		;;
	setup)
		shift
		cmd_setup "$@"
		;;
	hybrid)
		shift
		cmd_hybrid "$@"
		;;
	backup)
		shift
		cmd_backup "$@"
		;;
	restore)
		shift
		cmd_restore "$@"
		;;
	update)
		shift
		cmd_update "$@"
		;;
	config)
		shift
		cmd_config "$@"
		;;
	docs)
		shift
		cmd_docs "$@"
		;;
	help | -h | --help)
		usage
		;;
	"")
		usage
		exit 1
		;;
	*)
		usage
		exit 1
		;;
esac
