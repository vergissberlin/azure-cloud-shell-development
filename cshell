ask() {
	local prompt="$1"
	local default="${2:-}"
	local value
	if [[ -n "$default" ]]; then
		read -rp "${prompt} [${default}]: " value
		echo "${value:-$default}"
	else
		read -rp "${prompt}: " value
		echo "$value"
	fi
}

require_root() {
	if [[ $EUID -ne 0 ]]; then
		error "This step requires root privileges. Please run with sudo."
		exit 1
	fi
}

command_exists() {
	command -v "$1" &>/dev/null
}

append_line_if_missing() {
	local target_file="$1"
	local line="$2"

	touch "${target_file}"
	if ! grep -Fqx "${line}" "${target_file}"; then
		echo "${line}" >>"${target_file}"
	fi
}

install_bash_completion() {
	local bash_completion_dir="${HOME}/.local/share/bash-completion/completions"
	local bash_completion_file="${bash_completion_dir}/${SCRIPT_NAME}"
	local bashrc_file="${HOME}/.bashrc"
	local command_list="${CSHELL_COMMANDS[*]}"

	mkdir -p "${bash_completion_dir}"
	cat >"${bash_completion_file}" <<EOF
_${SCRIPT_NAME}_completions() {
  local cur
  COMPREPLY=()
  cur="\${COMP_WORDS[COMP_CWORD]}"
  COMPREPLY=(\$(compgen -W "${command_list}" -- "\${cur}"))
}
complete -F _${SCRIPT_NAME}_completions ${SCRIPT_NAME}
EOF

	append_line_if_missing "${bashrc_file}" ""
	append_line_if_missing "${bashrc_file}" "# Added by cshell setup: bash completion"
	append_line_if_missing "${bashrc_file}" "[[ -r /usr/share/bash-completion/bash_completion ]] && . /usr/share/bash-completion/bash_completion"
	append_line_if_missing "${bashrc_file}" "[[ -r ${bash_completion_file} ]] && . ${bash_completion_file}"

	success "Bash completion installed: ${bash_completion_file}"
	info "Run 'source ~/.bashrc' or start a new bash session to load completion."
}

install_shell_completion() {
	if command_exists bash; then
		if ! install_bash_completion; then
			warn "Could not install bash completion for ${SCRIPT_NAME}."
			warn "Completion setup finished with warnings."
			return 1
		fi
	else
		warn "bash not found. Skipping completion setup."
		return 1
	fi

	success "Autocomplete setup completed for bash."
}

is_azure_cloud_shell() {
	[[ -n "${ACC_CLOUD:-}" || -n "${AZURE_HTTP_USER_AGENT:-}" || -n "${CLOUD_SHELL:-}" ]]
}

curl_github() {
	curl -fsSL --max-time 25 --connect-timeout 10 "$@"
}

resolve_latest_release_tag() {
	local latest_json latest_tag

	if ! command_exists curl; then
		return 1
	fi

	latest_json="$(curl_github "${LATEST_RELEASE_API}" 2>/dev/null || true)"
	latest_tag="$(printf '%s' "${latest_json}" | sed -n 's/.*"tag_name":[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
	[[ -n "${latest_tag}" ]] || return 1
	printf '%s\n' "${latest_tag}"
}

# Prints two lines: tarball URL then .sha256 URL (empty lines if missing / python error).
release_asset_urls_from_json() {
	local json="$1"
	local version="$2"
	if ! command_exists python3; then
		printf '\n'
		return 1
	fi
	python3 -c '
import json, sys
payload = sys.stdin.read()
ver = sys.argv[1]
try:
    j = json.loads(payload)
except json.JSONDecodeError:
    sys.exit(1)
want_tgz = "cshell-%s.tar.gz" % ver
want_sha = want_tgz + ".sha256"
assets = {
    a.get("name"): a.get("browser_download_url")
    for a in j.get("assets", [])
    if a.get("name")
}
print(assets.get(want_tgz, "") or "")
print(assets.get(want_sha, "") or "")
' "${version}" <<<"${json}" 2>/dev/null || printf '\n'
}

# Download GitHub release tarball + checksum, verify, extract cshell to target_path. Returns 1 on soft-fail.
download_and_install_verified_release() {
	local tag="$1"
	local target_path="$2"
	local ver json tgz_url sha_url work tgz sha_file url_lines

	ver="${tag#v}"
	if ! command_exists python3; then
		return 1
	fi
	json="$(curl_github "${LATEST_RELEASE_API}" 2>/dev/null || true)"
	[[ -n "${json}" ]] || return 1

	url_lines="$(release_asset_urls_from_json "${json}" "${ver}")"
	tgz_url="$(printf '%s\n' "${url_lines}" | sed -n '1p')"
	sha_url="$(printf '%s\n' "${url_lines}" | sed -n '2p')"
	[[ -n "${tgz_url}" && -n "${sha_url}" ]] || return 1

	work="$(mktemp -d)"
	tgz="${work}/cshell-${ver}.tar.gz"
	sha_file="${work}/cshell-${ver}.tar.gz.sha256"

	if ! curl_github "${tgz_url}" -o "${tgz}"; then
		rm -rf "${work}"
		return 1
	fi
	if ! curl_github "${sha_url}" -o "${sha_file}"; then
		rm -rf "${work}"
		return 1
	fi

	if ! (cd "${work}" && sha256sum -c "$(basename "${sha_file}")"); then
		warn "Checksum verification failed for ${tgz##*/}."
		rm -rf "${work}"
		return 1
	fi

	if ! tar -xzf "${tgz}" -C "${work}"; then
		rm -rf "${work}"
		return 1
	fi

	if [[ ! -f "${work}/cshell" ]]; then
		warn "Release archive did not contain cshell at expected path."
		rm -rf "${work}"
		return 1
	fi

	chmod +x "${work}/cshell"
	mv -f "${work}/cshell" "${target_path}"
	rm -rf "${work}"
	return 0
}

is_newer_version() {
	local current_version="$1"
	local latest_version="$2"
	local highest_version

	if [[ -z "${current_version}" || -z "${latest_version}" || "${current_version}" == "${latest_version}" ]]; then
		return 1
	fi

	highest_version="$(printf '%s\n%s\n' "${current_version}" "${latest_version}" | sort -V | tail -n 1)"
	[[ "${highest_version}" == "${latest_version}" ]]
}

check_for_update_notice() {
	local latest_tag latest_version cache_file now last_ts

	[[ "${CSHELL_NO_UPDATE_CHECK:-0}" == "1" ]] && return 0

	mkdir -p "${UPDATE_CHECK_CACHE_DIR}" 2>/dev/null || true
	cache_file="${UPDATE_CHECK_CACHE_DIR}/last-update-check"
	now="$(date +%s)"
	if [[ -f "${cache_file}" ]]; then
		last_ts="$(head -n 1 "${cache_file}" 2>/dev/null || true)"
		if [[ -n "${last_ts}" ]] && [[ "$((now - last_ts))" -lt "${UPDATE_CHECK_CACHE_TTL_SECONDS}" ]]; then
			return 0
		fi
	fi

	latest_tag="$(resolve_latest_release_tag || true)"
	printf '%s\n' "${now}" >"${cache_file}" 2>/dev/null || true
	[[ -n "${latest_tag}" ]] || return 0

	latest_version="${latest_tag#v}"
	if is_newer_version "${SCRIPT_VERSION}" "${latest_version}"; then
		warn "A newer ${SCRIPT_NAME} version is available (${latest_version}). Run '${SCRIPT_NAME} update'."
	fi
}

is_path_writable_for_replace() {
	local target_path="$1"
	local target_dir

	if [[ -e "${target_path}" ]]; then
		[[ -w "${target_path}" ]]
		return
	fi

	target_dir="$(dirname "${target_path}")"
	[[ -w "${target_dir}" ]]
}

resolve_update_target_path() {
	local current_path

	current_path="$(command -v "${SCRIPT_NAME}" 2>/dev/null || true)"
	if [[ -n "${current_path}" ]] && is_path_writable_for_replace "${current_path}"; then
		printf '%s\n' "${current_path}"
		return 0
	fi

	if is_path_writable_for_replace "${UPDATE_INSTALL_PATH_DEFAULT}"; then
		printf '%s\n' "${UPDATE_INSTALL_PATH_DEFAULT}"
		return 0
	fi

	mkdir -p "$(dirname "${INSTALL_PATH_USER}")"
	printf '%s\n' "${INSTALL_PATH_USER}"
}

should_run_update_notice() {
	local command_name="${1:-}"
	case "${command_name}" in
		init | setup | hybrid | backup | restore | update) return 0 ;;
		*) return 1 ;;
	esac
}

upload_blob_with_fallback() {
	local account_name="$1"
	local container_name="$2"
	local blob_name="$3"
	local file_path="$4"
	local cmd_output

	if cmd_output=$(az storage blob upload \
		--account-name "${account_name}" \
		--container-name "${container_name}" \
		--name "${blob_name}" \
		--file "${file_path}" \
		--auth-mode login \
		--only-show-errors 2>&1); then
		return 0
	fi

	warn "Upload with Azure AD login failed. Trying account key from ${ENV_FILE} ..."
	if [[ -n "${AZURE_STORAGE_ACCOUNT_KEY:-}" ]]; then
		if cmd_output=$(az storage blob upload \
			--account-name "${account_name}" \
			--container-name "${container_name}" \
			--name "${blob_name}" \
			--file "${file_path}" \
			--auth-mode key \
			--account-key "${AZURE_STORAGE_ACCOUNT_KEY}" \
			--only-show-errors 2>&1); then
			return 0
		fi
		warn "Upload with account key also failed."
		warn "${cmd_output}"
		return 1
	fi

	warn "${cmd_output}"
	warn "No AZURE_STORAGE_ACCOUNT_KEY set in ${ENV_FILE}."
	return 1
}

download_blob_with_fallback() {
	local account_name="$1"
	local container_name="$2"
	local blob_name="$3"
	local file_path="$4"
	local cmd_output

	if cmd_output=$(az storage blob download \
		--account-name "${account_name}" \
		--container-name "${container_name}" \
		--name "${blob_name}" \
		--file "${file_path}" \
		--auth-mode login \
		--only-show-errors 2>&1); then
		return 0
	fi

	warn "Download with Azure AD login failed. Trying account key from ${ENV_FILE} ..."
	if [[ -n "${AZURE_STORAGE_ACCOUNT_KEY:-}" ]]; then
		if cmd_output=$(az storage blob download \
			--account-name "${account_name}" \
			--container-name "${container_name}" \
			--name "${blob_name}" \
			--file "${file_path}" \
			--auth-mode key \
			--account-key "${AZURE_STORAGE_ACCOUNT_KEY}" \
			--only-show-errors 2>&1); then
			return 0
		fi
		warn "Download with account key also failed."
		warn "${cmd_output}"
		return 1
	fi

	warn "${cmd_output}"
	warn "No AZURE_STORAGE_ACCOUNT_KEY set in ${ENV_FILE}."
	return 1
}

# ---------------------------------------------------------------------------
# setup
# ---------------------------------------------------------------------------

cmd_setup() {
	section "SETUP" "cshell setup workflow" "cyan"

	# ── 1. Install cshell binary ──────────────────────────────────────────────
	local install_path
	if is_azure_cloud_shell; then
		info "Azure Cloud Shell detected. Using user-space install defaults."
	fi

	if [[ $EUID -eq 0 ]]; then
		install_path="${INSTALL_PATH_DEFAULT}"
	else
		install_path="${INSTALL_PATH_USER}"
		mkdir -p "$(dirname "${install_path}")"
	fi

	info "Installing ${SCRIPT_NAME} to ${install_path} ..."
	local source_path target_path
	source_path="$(cshell_realpath "$0" || printf '%s\n' "$0")"
	target_path="$(cshell_realpath "${install_path}" 2>/dev/null || true)"
	if [[ -n "${target_path}" && "${source_path}" == "${target_path}" ]]; then
		info "${SCRIPT_NAME} is already installed at ${install_path}. Skipping copy."
	else
		cp "${source_path}" "${install_path}"
		chmod +x "${install_path}"
		success "cshell installed to ${install_path}"
	fi
	if [[ "${install_path}" == "${INSTALL_PATH_USER}" ]]; then
		if [[ ":${PATH}:" != *":${HOME}/.local/bin:"* ]]; then
			warn "${HOME}/.local/bin is not in PATH. Add this to your shell profile:"
			# Intentional single quotes: paste snippet so $HOME/$PATH expand in the user's shell.
			# shellcheck disable=SC2016
			echo '  export PATH="$HOME/.local/bin:$PATH"'
		fi
	fi

	# ── 2. Configure shell completion ─────────────────────────────────────────
	section "AUTOCOMPLETE" "Install command completion for cshell" "cyan"
	install_shell_completion || warn "Autocomplete setup encountered an unexpected issue."

	# ── 3. Install gcloud CLI (Apigee hybrid development) ────────────────────
	if command_exists gcloud; then
		success "gcloud is already installed ($(gcloud --version 2>&1 | head -1))"
	else
		info "Installing Google Cloud SDK ..."
		if command_exists apt-get && [[ $EUID -eq 0 ]]; then
			apt-get update -qq
			apt-get install -y ca-certificates gnupg curl
			echo "deb [signed-by=/usr/share/keyrings/cloud.google.gpg] \
https://packages.cloud.google.com/apt cloud-sdk main" \
				| tee /etc/apt/sources.list.d/google-cloud-sdk.list
			curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg \
				| gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg
			apt-get update -qq
			apt-get install -y google-cloud-cli
		elif command_exists brew; then
			brew install --cask google-cloud-sdk
		else
			info "No apt/brew found. Using official tarball installer ..."
			local tmp_dir gcloud_tar gcloud_root gcloud_bin target_bin os arch
			tmp_dir="$(mktemp -d)"
			os="$(uname -s | tr '[:upper:]' '[:lower:]')"
			arch="$(uname -m)"
			case "${arch}" in
				x86_64 | amd64) arch="x86_64" ;;
				aarch64 | arm64) arch="arm" ;;
				*)
					error "Unsupported architecture for gcloud installer: ${arch}"
					exit 1
					;;
			esac
			gcloud_tar="${tmp_dir}/google-cloud-cli.tar.gz"
			curl -fsSL "https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-cli-${os}-${arch}.tar.gz" -o "${gcloud_tar}"
			tar -xzf "${gcloud_tar}" -C "${tmp_dir}"
			gcloud_root="${tmp_dir}/google-cloud-sdk"
			"${gcloud_root}/install.sh" --quiet --path-update=true --usage-reporting=false --command-completion=true
			gcloud_bin="${gcloud_root}/bin/gcloud"
			if [[ -x "${gcloud_bin}" ]]; then
				if [[ $EUID -eq 0 ]]; then
					target_bin="/usr/local/bin/gcloud"
				else
					mkdir -p "${HOME}/.local/bin"
					target_bin="${HOME}/.local/bin/gcloud"
				fi
				cp "${gcloud_bin}" "${target_bin}"
				chmod +x "${target_bin}"
			else
				error "gcloud binary not found after installer run."
				exit 1
			fi
		fi
		success "gcloud installed"
	fi

	# ── 4. Interactive storage-account setup ─────────────────────────────────
	section "AZURE STORAGE" "Backup configuration" "blue"
	local storage_account container_name storage_account_key

	if [[ -f "${ENV_FILE}" ]]; then
		cshell_env_load "${ENV_FILE}"
	fi

	storage_account=$(ask "Azure Storage Account name" "${AZURE_STORAGE_ACCOUNT:-}")
	container_name=$(ask "Azure Blob Container name" "${AZURE_STORAGE_CONTAINER:-backups}")
	storage_account_key=$(ask "Azure Storage Account key (optional; enables upload fallback without RBAC role)" "${AZURE_STORAGE_ACCOUNT_KEY:-}")

	cshell_env_write_setup_storage_block "${ENV_FILE}" "${storage_account}" "${container_name}" "${storage_account_key}"

	success "Storage config saved to ${ENV_FILE}"
	info "Upload command that will be used during backup:"
	bullet_list \
		"az storage blob upload \\" \
		"--account-name ${storage_account} \\" \
		"--container-name ${container_name} \\" \
		"--name archive.zip \\" \
		"--file ${ARCHIVE_FILE}"
}

