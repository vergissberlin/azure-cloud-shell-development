ask() {
	local prompt="$1"
	local default="${2:-}"
	local value
	if [[ "${APIGEE_SETUP_NONINTERACTIVE:-0}" == "1" ]]; then
		printf '%s\n' "${default}"
		return 0
	fi
	if [[ -n "$default" ]]; then
		read -rp "${prompt} [${default}]: " value
		echo "${value:-$default}"
	else
		read -rp "${prompt}: " value
		echo "$value"
	fi
}

require_root() {
	if [[ $EUID -ne 0 ]]; then
		error "This step requires root privileges. Please run with sudo."
		exit 1
	fi
}

command_exists() {
	command -v "$1" &>/dev/null
}

# Return 0 if Helm client version is >= min (e.g. 3.14.0). Expects "helm version --short" like v3.14.0.
helm_meets_min_version() {
	local min_ver="$1"
	local hv
	if ! command_exists helm; then
		return 1
	fi
	hv="$(helm version --short 2>/dev/null | sed -E 's/^v//; s/-.*//')"
	[[ -n "${hv}" ]] || return 1
	local max_ver
	max_ver="$(printf '%s\n' "${min_ver}" "${hv}" | sort -V | tail -n1)"
	[[ "${max_ver}" == "${hv}" ]]
}

append_line_if_missing() {
	local target_file="$1"
	local line="$2"

	touch "${target_file}"
	if ! grep -Fqx "${line}" "${target_file}"; then
		echo "${line}" >>"${target_file}"
	fi
}

install_bash_completion() {
	local bash_completion_dir="${HOME}/.local/share/bash-completion/completions"
	local bash_completion_file="${bash_completion_dir}/${SCRIPT_NAME}"
	local bashrc_file="${HOME}/.bashrc"
	local command_list="${CSHELL_COMMANDS[*]}"

	mkdir -p "${bash_completion_dir}"
	cat >"${bash_completion_file}" <<EOF
_${SCRIPT_NAME}_completions() {
  local cur
  COMPREPLY=()
  cur="\${COMP_WORDS[COMP_CWORD]}"
  COMPREPLY=(\$(compgen -W "${command_list}" -- "\${cur}"))
}
complete -F _${SCRIPT_NAME}_completions ${SCRIPT_NAME}
EOF

	append_line_if_missing "${bashrc_file}" ""
	append_line_if_missing "${bashrc_file}" "# Added by cshell setup: bash completion"
	append_line_if_missing "${bashrc_file}" "[[ -r /usr/share/bash-completion/bash_completion ]] && . /usr/share/bash-completion/bash_completion"
	append_line_if_missing "${bashrc_file}" "[[ -r ${bash_completion_file} ]] && . ${bash_completion_file}"

	success "Bash completion installed: ${bash_completion_file}"
	info "Run 'source ~/.bashrc' or start a new bash session to load completion."
}

# Ensure ~/.bashrc sources ~/.cshell-env-exports.sh once (allowlisted exports from ~/.cshell.env).
cshell_install_bashrc_env_exports_hook() {
	local bashrc_file="${HOME}/.bashrc"

	touch "${bashrc_file}"
	append_line_if_missing "${bashrc_file}" ""
	append_line_if_missing "${bashrc_file}" "# Added by cshell: export allowlisted variables from ~/.cshell.env"
	append_line_if_missing "${bashrc_file}" "[[ -r \"\${HOME}/.cshell-env-exports.sh\" ]] && . \"\${HOME}/.cshell-env-exports.sh\""
}

# Login shells often read ~/.profile (and sometimes ~/.bash_profile) without ~/.bashrc — hook those too.
cshell_install_profile_env_exports_hook() {
	local profile_file="${HOME}/.profile"

	touch "${profile_file}"
	append_line_if_missing "${profile_file}" ""
	append_line_if_missing "${profile_file}" "# Added by cshell: export allowlisted variables from ~/.cshell.env (bash login shells)"
	# Literal \${…} is required in ~/.profile (do not expand at cshell install time).
	# shellcheck disable=SC2016
	append_line_if_missing "${profile_file}" 'if [ -n "${BASH_VERSION:-}" ]; then [[ -r "${HOME}/.cshell-env-exports.sh" ]] && . "${HOME}/.cshell-env-exports.sh"; fi'
}

cshell_install_bash_profile_env_exports_hook() {
	local bpf="${HOME}/.bash_profile"

	[[ -f "${bpf}" ]] || return 0
	touch "${bpf}"
	append_line_if_missing "${bpf}" ""
	append_line_if_missing "${bpf}" "# Added by cshell: export allowlisted variables from ~/.cshell.env"
	append_line_if_missing "${bpf}" "[[ -r \"\${HOME}/.cshell-env-exports.sh\" ]] && . \"\${HOME}/.cshell-env-exports.sh\""
}

cshell_install_shell_env_exports_hooks() {
	cshell_install_bashrc_env_exports_hook
	cshell_install_profile_env_exports_hook
	cshell_install_bash_profile_env_exports_hook
}

# Regenerate ~/.cshell-env-exports.sh from ENV_FILE and install shell hooks (bash 4+).
cshell_env_sync_exports() {
	local exports="${HOME}/.cshell-env-exports.sh"

	if [[ ! -f "${ENV_FILE}" ]]; then
		rm -f "${exports}" 2>/dev/null || true
		return 0
	fi
	if ! cshell_env_write_export_snippet "${ENV_FILE}"; then
		return 1
	fi
	if command_exists bash; then
		cshell_install_shell_env_exports_hooks
	fi
	info "Shell export snippet: ${exports} — new bash sessions load it from ~/.bashrc (and ~/.profile for login bash; ~/.bash_profile if present). This shell: source \"${exports}\" or open a new terminal."
}

install_shell_completion() {
