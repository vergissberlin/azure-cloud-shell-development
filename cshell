cmd_setup() {
	section "SETUP" "cshell setup workflow" "cyan"

	# ── 1. Install cshell binary ──────────────────────────────────────────────
	local install_path
	if is_azure_cloud_shell; then
		info "Azure Cloud Shell detected. Using user-space install defaults."
	fi

	if [[ $EUID -eq 0 ]]; then
		install_path="${INSTALL_PATH_DEFAULT}"
	else
		install_path="${INSTALL_PATH_USER}"
		mkdir -p "$(dirname "${install_path}")"
	fi

	info "Installing ${SCRIPT_NAME} to ${install_path} ..."
	local source_path target_path
	source_path="$(cshell_realpath "$0" || printf '%s\n' "$0")"
	target_path="$(cshell_realpath "${install_path}" 2>/dev/null || true)"
	if [[ -n "${target_path}" && "${source_path}" == "${target_path}" ]]; then
		info "${SCRIPT_NAME} is already installed at ${install_path}. Skipping copy."
	else
		cp "${source_path}" "${install_path}"
		chmod +x "${install_path}"
		success "cshell installed to ${install_path}"
	fi
	if [[ "${install_path}" == "${INSTALL_PATH_USER}" ]]; then
		if [[ ":${PATH}:" != *":${HOME}/.local/bin:"* ]]; then
			warn "${HOME}/.local/bin is not in PATH. Add this to your shell profile:"
			# Intentional single quotes: paste snippet so $HOME/$PATH expand in the user's shell.
			# shellcheck disable=SC2016
			echo '  export PATH="$HOME/.local/bin:$PATH"'
		fi
	fi

	# ── 2. Configure shell completion ─────────────────────────────────────────
	section "AUTOCOMPLETE" "Install command completion for cshell" "cyan"
	install_shell_completion || warn "Autocomplete setup encountered an unexpected issue."

	# ── 3. Install gcloud CLI (Apigee hybrid development) ────────────────────
	# A broken ~/.local/bin/gcloud (e.g. copied from google-cloud-sdk/bin without
	# the rest of the tree) resolves CLOUDSDK_ROOT_DIR to ~/.local and fails with
	# "can't open file '.../.local/lib/gcloud.py'". Treat non-working gcloud as missing.
	if command_exists gcloud && gcloud --version >/dev/null 2>&1; then
		success "gcloud is already installed ($(gcloud --version 2>&1 | head -1))"
	else
		if command_exists gcloud; then
			warn "gcloud is on PATH but does not run; reinstalling Google Cloud SDK ..."
		fi
		info "Installing Google Cloud SDK ..."
		if command_exists apt-get && [[ $EUID -eq 0 ]]; then
			apt-get update -qq
			apt-get install -y ca-certificates gnupg curl
			echo "deb [signed-by=/usr/share/keyrings/cloud.google.gpg] \
https://packages.cloud.google.com/apt cloud-sdk main" \
				| tee /etc/apt/sources.list.d/google-cloud-sdk.list
			curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg \
				| gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg
			apt-get update -qq
			apt-get install -y google-cloud-cli
		elif command_exists brew; then
			brew install --cask google-cloud-sdk
		else
			info "No apt/brew found. Using official tarball installer ..."
			local tmp_dir gcloud_tar gcloud_root target_bin os arch
			tmp_dir="$(mktemp -d)"
			os="$(uname -s | tr '[:upper:]' '[:lower:]')"
			arch="$(uname -m)"
			case "${arch}" in
				x86_64 | amd64) arch="x86_64" ;;
				aarch64 | arm64) arch="arm" ;;
				*)
					error "Unsupported architecture for gcloud installer: ${arch}"
					exit 1
					;;
			esac
			gcloud_tar="${tmp_dir}/google-cloud-cli.tar.gz"
			curl -fsSL "https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-cli-${os}-${arch}.tar.gz" -o "${gcloud_tar}"
			# Install tree under $HOME so the launcher keeps LIB/CLOUDSDK_ROOT_DIR valid.
			tar -xzf "${gcloud_tar}" -C "${HOME}"
			rm -rf "${tmp_dir}"
			gcloud_root="${HOME}/google-cloud-sdk"
			if [[ ! -x "${gcloud_root}/install.sh" ]]; then
				error "Google Cloud SDK unpack failed (missing ${gcloud_root}/install.sh)."
				exit 1
			fi
			"${gcloud_root}/install.sh" --quiet --path-update=true --usage-reporting=false --command-completion=true
			if [[ -x "${gcloud_root}/bin/gcloud" ]]; then
				if [[ $EUID -eq 0 ]]; then
					mkdir -p /usr/local/bin
					target_bin="/usr/local/bin/gcloud"
				else
					mkdir -p "${HOME}/.local/bin"
					target_bin="${HOME}/.local/bin/gcloud"
				fi
				# Symlink: a copy here breaks _cloudsdk_root_dir() (expects .../google-cloud-sdk/bin/gcloud).
				ln -sf "${gcloud_root}/bin/gcloud" "${target_bin}"
			else
				error "gcloud binary not found after installer run."
				exit 1
			fi
		fi
		success "gcloud installed"
	fi

	# ── 4. Interactive storage-account setup ─────────────────────────────────
	section "AZURE STORAGE" "Backup configuration" "blue"
	local storage_account container_name storage_account_key helm_charts_home_setup

	if [[ -f "${ENV_FILE}" ]]; then
		cshell_env_load "${ENV_FILE}"
	fi

	mkdir -p "${DEFAULT_APIGEE_HELM_CHARTS_HOME}"
	helm_charts_home_setup="$(cshell_realpath "${DEFAULT_APIGEE_HELM_CHARTS_HOME}" 2>/dev/null || printf '%s\n' "${DEFAULT_APIGEE_HELM_CHARTS_HOME}")"
	info "Apigee Helm charts home (default): ${helm_charts_home_setup}"
	info "Override with APIGEE_HELM_CHARTS_HOME in ${ENV_FILE} if you need a different path."

	storage_account=$(ask "Azure Storage Account name" "${AZURE_STORAGE_ACCOUNT:-}")
	container_name=$(ask "Azure Blob Container name" "${AZURE_STORAGE_CONTAINER:-backups}")
	storage_account_key=$(ask "Azure Storage Account key (optional; enables upload fallback without RBAC role)" "${AZURE_STORAGE_ACCOUNT_KEY:-}")

	cshell_env_write_setup_storage_block "${ENV_FILE}" "${storage_account}" "${container_name}" "${storage_account_key}" "${helm_charts_home_setup}"

	if command_exists bash; then
		cshell_env_sync_exports || warn "Could not refresh shell export snippet (bash 4+ required for ~/.cshell-env-exports.sh)."
	else
		warn "bash not found; wrote ${ENV_FILE} only. Install bash or run: source ~/.cshell-env-exports.sh after generating it with cshell on a system with bash 4+."
	fi

	success "Storage config saved to ${ENV_FILE}"
	info "Upload command that will be used during backup:"
	bullet_list \
		"az storage blob upload \\" \
		"--account-name ${storage_account} \\" \
		"--container-name ${container_name} \\" \
		"--name archive.zip \\" \
		"--file ${ARCHIVE_FILE} \\" \
		"--overwrite"
}

