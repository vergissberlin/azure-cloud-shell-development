# Variables that must be non-empty for a useful Hybrid env (see hybrid block write). Not listed:
# CONTROL_PLANE_LOCATION (optional). CHART_REPO / CHART_VERSION use script defaults if unset in file.
HYBRID_REQUIRED_VARS=(
	PROJECT_ID
	ORG_NAME
	ORG_DISPLAY_NAME
	ORGANIZATION_DESCRIPTION
	ANALYTICS_REGION
	RUNTIMETYPE
	CLUSTER_NAME
	CLUSTER_REGION
	APIGEE_NAMESPACE
	ENVIRONMENT_NAME
	ENV_GROUP
	ENV_GROUP_RELEASE_NAME
	DOMAIN
	APIGEE_HELM_CHARTS_HOME
)

# Hybrid install checklist status glyphs (human output + JSON symbol field). Independent of CHECKMARK/CROSS in success/error.
HYBRID_CHK_PASS='✓'
HYBRID_CHK_FAIL='✗'
HYBRID_CHK_SKIP='○'

# After cshell_env_load "${ENV_FILE}", sets hybrid_missing_required to missing key names.
cmd_hybrid_env_fill_missing_array() {
	hybrid_missing_required=()
	local k
	for k in "${HYBRID_REQUIRED_VARS[@]}"; do
		# shellcheck disable=SC2248
		[[ -n "${!k:-}" ]] || hybrid_missing_required+=("${k}")
	done
}

cmd_hybrid_env_report_missing_vars() {
	error "Missing or empty Hybrid environment variable(s): ${hybrid_missing_required[*]}"
	info "Set them in ${ENV_FILE} (Hybrid block) or run '${SCRIPT_NAME} hybrid' interactively."
}

cmd_hybrid_env_file_must_exist() {
	if [[ ! -f "${ENV_FILE}" || ! -r "${ENV_FILE}" ]]; then
		error "${ENV_FILE} is missing or not readable. Run '${SCRIPT_NAME} hybrid' to create it, or create the file manually."
		return 1
	fi
	if [[ ! -s "${ENV_FILE}" ]]; then
		error "${ENV_FILE} is empty. Run '${SCRIPT_NAME} hybrid' to create it, or add configuration manually."
		return 1
	fi
	return 0
}

# Load ENV_FILE and ensure all Hybrid vars required for install/check/export are non-empty. Returns 1 on error.
cmd_hybrid_env_validate() {
	cmd_hybrid_env_file_must_exist || return 1

	cshell_env_load "${ENV_FILE}"
	cmd_hybrid_env_fill_missing_array

	if [[ "${#hybrid_missing_required[@]}" -gt 0 ]]; then
		cmd_hybrid_env_report_missing_vars
		return 1
	fi

	return 0
}

# One checklist row: colored status + title, dimmed Doc URL line, optional note, trailing blank line.
# Args: step_num title url status_symbol [note]
cshell_hybrid_checklist_emit_step() {
	local num="$1" title="$2" url="$3" sym="$4" note="${5:-}"
	local num_fmt title_prefix cont_ind dim=''
	num_fmt="$(printf '%2d' "${num}")"
	# Unstyled prefix before title must match line 1 (colors have zero display width).
	title_prefix="  ${sym}  ${num_fmt}. "
	cont_ind=$(printf '%*s' "${#title_prefix}" '')
	if cshell_cli_colors_active; then
		dim="${DIM:-\033[2m}"
	fi
	local sym_color="${GREEN}" title_color="${GREEN}"

	if [[ "${sym}" == "${HYBRID_CHK_FAIL}" ]]; then
		sym_color="${RED}"
		title_color="${RED}"
	elif [[ "${sym}" == "${HYBRID_CHK_SKIP}" ]]; then
		sym_color="${YELLOW}"
		title_color="${YELLOW}"
	fi

	echo -e "  ${sym_color}${sym}${RESET}  ${title_color}${num_fmt}. ${title}${RESET}"
	echo -e "${cont_ind}${dim}Doc: ${url}${RESET}"

	if [[ -n "${note}" ]]; then
		if [[ "${sym}" == "${HYBRID_CHK_FAIL}" ]]; then
			echo -e "${cont_ind}${RED}↳ ${note}${RESET}"
		elif [[ "${sym}" == "${HYBRID_CHK_SKIP}" ]]; then
			echo -e "${cont_ind}${YELLOW}↳ ${note}${RESET}"
		else
			echo -e "${cont_ind}${dim}↳ ${note}${RESET}"
		fi
	fi
	echo
}

# Escape a string for use inside JSON double quotes (minimal: \ " CR LF).
cshell_json_escape() {
	local s="$1"
	s="${s//\\/\\\\}"
	s="${s//\"/\\\"}"
	s="${s//$'\n'/\\n}"
	s="${s//$'\r'/\\r}"
	printf '%s' "${s}"
}

cshell_hybrid_step_status_from_sym() {
	local sym="$1"
	if [[ "${sym}" == "${HYBRID_CHK_PASS}" ]]; then
		printf '%s' pass
	elif [[ "${sym}" == "${HYBRID_CHK_FAIL}" ]]; then
		printf '%s' fail
	elif [[ "${sym}" == "${HYBRID_CHK_SKIP}" ]]; then
		printf '%s' skip
	else
		printf '%s' skip
	fi
}

# One checklist step as JSON object (single line).
cshell_hybrid_json_step() {
	local id="$1" title="$2" url="$3" sym="$4" note="$5"
	local st
	st="$(cshell_hybrid_step_status_from_sym "${sym}")"
	printf '{"id":%s,"title":"%s","url":"%s","symbol":"%s","status":"%s","note":"%s"}' \
		"${id}" "$(cshell_json_escape "${title}")" "$(cshell_json_escape "${url}")" \
		"$(cshell_json_escape "${sym}")" "${st}" "$(cshell_json_escape "${note}")"
}

# Print numbered Hybrid v1.16 install checklist (docs order). Uses current shell state after cshell_env_load.
# $1: "1" when invoked from hybrid --check --strict (banner / JSON strict field only).
# $2: "1" for machine-readable JSON on stdout (no ANSI, no human banners).
# $3: emit only this step number (1–13) for human output; "0" = print all rows (default). Ignored when json_mode is 1.
# Sets hybrid_checklist_fail_count to the number of rows with HYBRID_CHK_FAIL (for --strict).
cmd_hybrid_install_checklist_print() {
	local strict_banner="${1:-0}"
	local json_mode="${2:-0}"
	local emit_only_step="${3:-0}"

	local sym_done="${HYBRID_CHK_PASS}"
	local sym_fail="${HYBRID_CHK_FAIL}"
	local sym_skip="${HYBRID_CHK_SKIP}"

	hybrid_checklist_fail_count=0

	if [[ "${json_mode}" != "1" && "${emit_only_step}" == "0" ]]; then
		if [[ "${strict_banner}" == "1" ]]; then
			info "Hybrid v1.16 install checklist (documentation order). With --strict, exit status also reflects any ${HYBRID_CHK_FAIL} below (${HYBRID_CHK_SKIP} is not a failure)."
		else
			info "Hybrid v1.16 install checklist (documentation order; without --strict, exit status still reflects only ${ENV_FILE} required variables):"
		fi
	fi

	local step1_sym="${sym_done}"
	((${#hybrid_missing_required[@]} > 0)) && step1_sym="${sym_fail}"

	local step2_sym="${sym_skip}"
	local step2_note="kubectl not in PATH"
	if command_exists kubectl; then
		step2_note=""
		if kubectl cluster-info --request-timeout=5s &>/dev/null; then
			step2_sym="${sym_done}"
		else
			step2_sym="${sym_fail}"
			step2_note="cluster not reachable or not configured"
		fi
	fi

	local step3_sym="${sym_fail}"
	local c missing_chart=0
	if [[ -n "${APIGEE_HELM_CHARTS_HOME:-}" && -d "${APIGEE_HELM_CHARTS_HOME}" ]]; then
		missing_chart=0
		for c in "${APIGEE_CHARTS[@]}"; do
			if [[ ! -d "${APIGEE_HELM_CHARTS_HOME}/${c}" ]]; then
				missing_chart=1
				break
			fi
		done
		((missing_chart == 0)) && step3_sym="${sym_done}"
	else
		step3_sym="${sym_fail}"
	fi

	local step4_sym="${sym_skip}"
	local step4_note="kubectl not in PATH"
	if command_exists kubectl; then
		step4_note=""
		if [[ -n "${APIGEE_NAMESPACE:-}" ]] \
			&& kubectl get namespace "${APIGEE_NAMESPACE}" --request-timeout=5s &>/dev/null; then
			step4_sym="${sym_done}"
		else
			step4_sym="${sym_fail}"
			if [[ -z "${APIGEE_NAMESPACE:-}" ]]; then
				step4_note="APIGEE_NAMESPACE unset"
			else
				step4_note="namespace not found"
			fi
		fi
	fi

	cshell_hybrid_eval_checklist_steps_5_13 "${sym_done}" "${sym_fail}" "${sym_skip}" "${DOC_INSTALL_HYBRID}"

	if [[ "${emit_only_step}" != "0" && "${json_mode}" != "1" ]]; then
		case "${emit_only_step}" in
			1) cshell_hybrid_checklist_emit_step 1 "Before you begin" "${DOC_BEFORE_BEGIN}" "${step1_sym}" "" ;;
			2) cshell_hybrid_checklist_emit_step 2 "Create cluster" "${DOC_INSTALL_CREATE_CLUSTER}" "${step2_sym}" "${step2_note}" ;;
			3) cshell_hybrid_checklist_emit_step 3 "Download Helm charts" "${DOC_DOWNLOAD_CHARTS}" "${step3_sym}" "" ;;
			4) cshell_hybrid_checklist_emit_step 4 "Create namespace" "${DOC_INSTALL_CREATE_NAMESPACE}" "${step4_sym}" "${step4_note}" ;;
			5) cshell_hybrid_checklist_emit_step 5 "Service accounts" "${DOC_INSTALL_SERVICE_ACCOUNTS}" "${HYBRID_STEP5_SYM}" "${HYBRID_STEP5_NOTE}" ;;
			6) cshell_hybrid_checklist_emit_step 6 "Service account authentication" "${DOC_INSTALL_SA_AUTH}" "${HYBRID_STEP6_SYM}" "${HYBRID_STEP6_NOTE}" ;;
			7) cshell_hybrid_checklist_emit_step 7 "TLS certificates" "${DOC_INSTALL_TLS}" "${HYBRID_STEP7_SYM}" "${HYBRID_STEP7_NOTE}" ;;
			8) cshell_hybrid_checklist_emit_step 8 "Overrides" "${DOC_INSTALL_OVERRIDES}" "${HYBRID_STEP8_SYM}" "${HYBRID_STEP8_NOTE}" ;;
			9) cshell_hybrid_checklist_emit_step 9 "Control plane access" "${DOC_INSTALL_CONTROL_PLANE}" "${HYBRID_STEP9_SYM}" "${HYBRID_STEP9_NOTE}" ;;
			10) cshell_hybrid_checklist_emit_step 10 "cert-manager" "${DOC_INSTALL_CERT_MANAGER}" "${HYBRID_STEP10_SYM}" "${HYBRID_STEP10_NOTE}" ;;
			11) cshell_hybrid_checklist_emit_step 11 "CRDs" "${DOC_INSTALL_CRDS}" "${HYBRID_STEP11_SYM}" "${HYBRID_STEP11_NOTE}" ;;
			12) cshell_hybrid_checklist_emit_step 12 "Helm install (Hybrid)" "${DOC_INSTALL_HELM_CHARTS}" "${HYBRID_STEP12_SYM}" "${HYBRID_STEP12_NOTE}" ;;
			13) cshell_hybrid_checklist_emit_step 13 "Community install guide" "${DOC_INSTALL_HYBRID}" "${HYBRID_STEP13_SYM}" "${HYBRID_STEP13_NOTE}" ;;
			*)
				error "Internal error: invalid emit_only_step '${emit_only_step}'."
				return 1
				;;
		esac
		return 0
	fi

	local _sym
	for _sym in "${step1_sym}" "${step2_sym}" "${step3_sym}" "${step4_sym}" \
		"${HYBRID_STEP5_SYM}" "${HYBRID_STEP6_SYM}" "${HYBRID_STEP7_SYM}" "${HYBRID_STEP8_SYM}" \
		"${HYBRID_STEP9_SYM}" "${HYBRID_STEP10_SYM}" "${HYBRID_STEP11_SYM}" "${HYBRID_STEP12_SYM}" "${HYBRID_STEP13_SYM}"; do
		[[ "${_sym}" == "${sym_fail}" ]] && hybrid_checklist_fail_count=$((hybrid_checklist_fail_count + 1))
	done

	if [[ "${json_mode}" == "1" ]]; then
		local strict_js='false'
		[[ "${strict_banner}" == "1" ]] && strict_js='true'
		local sj_out
		sj_out="$(cshell_hybrid_json_step 1 "Before you begin" "${DOC_BEFORE_BEGIN}" "${step1_sym}" "")"
		sj_out+=",$(cshell_hybrid_json_step 2 "Create cluster" "${DOC_INSTALL_CREATE_CLUSTER}" "${step2_sym}" "${step2_note}")"
		sj_out+=",$(cshell_hybrid_json_step 3 "Download Helm charts" "${DOC_DOWNLOAD_CHARTS}" "${step3_sym}" "")"
		sj_out+=",$(cshell_hybrid_json_step 4 "Create namespace" "${DOC_INSTALL_CREATE_NAMESPACE}" "${step4_sym}" "${step4_note}")"
		sj_out+=",$(cshell_hybrid_json_step 5 "Service accounts" "${DOC_INSTALL_SERVICE_ACCOUNTS}" "${HYBRID_STEP5_SYM}" "${HYBRID_STEP5_NOTE}")"
		sj_out+=",$(cshell_hybrid_json_step 6 "Service account authentication" "${DOC_INSTALL_SA_AUTH}" "${HYBRID_STEP6_SYM}" "${HYBRID_STEP6_NOTE}")"
		sj_out+=",$(cshell_hybrid_json_step 7 "TLS certificates" "${DOC_INSTALL_TLS}" "${HYBRID_STEP7_SYM}" "${HYBRID_STEP7_NOTE}")"
		sj_out+=",$(cshell_hybrid_json_step 8 "Overrides" "${DOC_INSTALL_OVERRIDES}" "${HYBRID_STEP8_SYM}" "${HYBRID_STEP8_NOTE}")"
		sj_out+=",$(cshell_hybrid_json_step 9 "Control plane access" "${DOC_INSTALL_CONTROL_PLANE}" "${HYBRID_STEP9_SYM}" "${HYBRID_STEP9_NOTE}")"
		sj_out+=",$(cshell_hybrid_json_step 10 "cert-manager" "${DOC_INSTALL_CERT_MANAGER}" "${HYBRID_STEP10_SYM}" "${HYBRID_STEP10_NOTE}")"
		sj_out+=",$(cshell_hybrid_json_step 11 "CRDs" "${DOC_INSTALL_CRDS}" "${HYBRID_STEP11_SYM}" "${HYBRID_STEP11_NOTE}")"
		sj_out+=",$(cshell_hybrid_json_step 12 "Helm install (Hybrid)" "${DOC_INSTALL_HELM_CHARTS}" "${HYBRID_STEP12_SYM}" "${HYBRID_STEP12_NOTE}")"
		sj_out+=",$(cshell_hybrid_json_step 13 "Community install guide" "${DOC_INSTALL_HYBRID}" "${HYBRID_STEP13_SYM}" "${HYBRID_STEP13_NOTE}")"
		printf '%s\n' "{\"schema\":\"cshell.hybrid_check.v1\",\"strict\":${strict_js},\"checklist_fail_count\":${hybrid_checklist_fail_count},\"steps\":[${sj_out}]}"
		return 0
	fi

	cshell_hybrid_checklist_emit_step 1 "Before you begin" "${DOC_BEFORE_BEGIN}" "${step1_sym}" ""
	cshell_hybrid_checklist_emit_step 2 "Create cluster" "${DOC_INSTALL_CREATE_CLUSTER}" "${step2_sym}" "${step2_note}"
	cshell_hybrid_checklist_emit_step 3 "Download Helm charts" "${DOC_DOWNLOAD_CHARTS}" "${step3_sym}" ""
	cshell_hybrid_checklist_emit_step 4 "Create namespace" "${DOC_INSTALL_CREATE_NAMESPACE}" "${step4_sym}" "${step4_note}"
	cshell_hybrid_checklist_emit_step 5 "Service accounts" "${DOC_INSTALL_SERVICE_ACCOUNTS}" "${HYBRID_STEP5_SYM}" "${HYBRID_STEP5_NOTE}"
	cshell_hybrid_checklist_emit_step 6 "Service account authentication" "${DOC_INSTALL_SA_AUTH}" "${HYBRID_STEP6_SYM}" "${HYBRID_STEP6_NOTE}"
	cshell_hybrid_checklist_emit_step 7 "TLS certificates" "${DOC_INSTALL_TLS}" "${HYBRID_STEP7_SYM}" "${HYBRID_STEP7_NOTE}"
	cshell_hybrid_checklist_emit_step 8 "Overrides" "${DOC_INSTALL_OVERRIDES}" "${HYBRID_STEP8_SYM}" "${HYBRID_STEP8_NOTE}"
	cshell_hybrid_checklist_emit_step 9 "Control plane access" "${DOC_INSTALL_CONTROL_PLANE}" "${HYBRID_STEP9_SYM}" "${HYBRID_STEP9_NOTE}"
	cshell_hybrid_checklist_emit_step 10 "cert-manager" "${DOC_INSTALL_CERT_MANAGER}" "${HYBRID_STEP10_SYM}" "${HYBRID_STEP10_NOTE}"
	cshell_hybrid_checklist_emit_step 11 "CRDs" "${DOC_INSTALL_CRDS}" "${HYBRID_STEP11_SYM}" "${HYBRID_STEP11_NOTE}"
	cshell_hybrid_checklist_emit_step 12 "Helm install (Hybrid)" "${DOC_INSTALL_HELM_CHARTS}" "${HYBRID_STEP12_SYM}" "${HYBRID_STEP12_NOTE}"
	cshell_hybrid_checklist_emit_step 13 "Community install guide" "${DOC_INSTALL_HYBRID}" "${HYBRID_STEP13_SYM}" "${HYBRID_STEP13_NOTE}"
	info "Vault-only or Workload Identity setups may not show ${HYBRID_CHK_PASS} for service-account rows; confirm against Google's docs if needed."
}

# Pull Apigee Hybrid OCI charts into $1 (helm on PATH, GCP registry auth). Returns 1 on fatal errors.
cmd_hybrid_pull_apigee_charts() {
	local helm_charts_home="$1"
	if ! command_exists helm; then
		error "helm is not installed. Install Helm v${HELM_MIN_VERSION}+ from ${DOC_HELM_INSTALL}"
		return 1
	fi
	if ! helm_meets_min_version "${HELM_MIN_VERSION}"; then
		error "helm must be version ${HELM_MIN_VERSION} or newer (Apigee Hybrid v1.16). Found: $(helm version --short 2>/dev/null || echo 'unknown')"
		info "Upgrade: ${DOC_HELM_INSTALL}"
		return 1
	fi
	info "Pulling OCI charts requires GCP auth for ${CHART_REPO} (e.g. gcloud auth login or gcloud auth application-default login). See: ${DOC_DOWNLOAD_CHARTS}"
	info "Downloading Apigee Hybrid Helm charts (version ${CHART_VERSION}) ..."
	(
		cd "${helm_charts_home}" || exit 1
		local chart
		for chart in "${APIGEE_CHARTS[@]}"; do
			info "Pulling ${chart} ..."
			rm -rf "${chart}"
			helm pull "${CHART_REPO}/${chart}" --version "${CHART_VERSION}" --untar
		done
	)
	success "Helm charts downloaded to ${helm_charts_home}"
	return 0
}

# Run automated slice for hybrid --step N (env already loaded and validated when required).
cmd_hybrid_run_step_actions() {
	local n="$1"
	case "${n}" in
		1)
			success "All required Hybrid environment variables are set in ${ENV_FILE}."
			;;
		2)
			info "Kubernetes cluster setup: ${DOC_INSTALL_CREATE_CLUSTER}"
			# shellcheck disable=SC2153
			cshell_hybrid_fetch_aks_kubeconfig "${AKS_RESOURCE_GROUP:-}" "${CLUSTER_NAME}"
			;;
		3)
			mkdir -p "${APIGEE_HELM_CHARTS_HOME}"
			cmd_hybrid_pull_apigee_charts "${APIGEE_HELM_CHARTS_HOME}" || return 1
			;;
		4)
			if ! command_exists kubectl; then
				warn "kubectl not in PATH — create namespace ${APIGEE_NAMESPACE} on the cluster manually. ${DOC_INSTALL_CREATE_NAMESPACE}"
				return 0
			fi
			if kubectl get namespace "${APIGEE_NAMESPACE}" --request-timeout=5s &>/dev/null; then
				info "Namespace '${APIGEE_NAMESPACE}' already exists."
			else
				if kubectl create namespace "${APIGEE_NAMESPACE}" --request-timeout=30s; then
					success "Created namespace '${APIGEE_NAMESPACE}'."
				else
					warn "kubectl create namespace failed — see ${DOC_INSTALL_CREATE_NAMESPACE}"
					return 1
				fi
			fi
			;;
		5)
			local sa_dir="${APIGEE_HELM_CHARTS_HOME}/service-accounts"
			mkdir -p "${sa_dir}"
			info "Service account key directory: ${sa_dir}"
			info "Documentation: ${DOC_INSTALL_SERVICE_ACCOUNTS}"
			local prefer_nonprod=0
			if cshell_hybrid_detect_nonprod; then
				prefer_nonprod=1
			elif [[ "${ENVIRONMENT_NAME:-}" =~ [Nn]on[-_]?[Pp]rod ]]; then
				prefer_nonprod=1
			fi
			if [[ "${prefer_nonprod}" == "1" ]]; then
				bullet_list \
					"Non-prod: place ${PROJECT_ID}-apigee-non-prod.json in ${sa_dir}/" \
					"Create the Apigee non-prod service account and download the key per Google docs."
			else
				local sfx paths=()
				for sfx in "${HYBRID_PROD_SA_SUFFIXES[@]}"; do
					paths+=("${sa_dir}/${PROJECT_ID}-apigee-${sfx}.json")
				done
				bullet_list "Production: expected key file paths (one per Apigee service account):" "${paths[@]}"
			fi
			;;
		6)
			info "Kubernetes secrets from keys: ${DOC_INSTALL_SA_AUTH}"
			local np_secret="${APIGEE_NONPROD_SA_SECRET:-apigee-non-prod-svc-account}"
			local np_json="${APIGEE_HELM_CHARTS_HOME}/service-accounts/${PROJECT_ID}-apigee-non-prod.json"
			info "Non-prod example: kubectl create secret generic ${np_secret} -n ${APIGEE_NAMESPACE} --from-file=service_account.json=${np_json}"
			;;
		7)
			local vhost="${APIGEE_HELM_CHARTS_HOME}/apigee-virtualhost"
			local crt_rel="${APIGEE_OVERRIDE_TLS_CERT_REL:-certs/tls.crt}"
			local key_rel="${APIGEE_OVERRIDE_TLS_KEY_REL:-certs/tls.key}"
			local crt_abs="${vhost}/${crt_rel}"
			local key_abs="${vhost}/${key_rel}"
			mkdir -p "$(dirname "${crt_abs}")" "$(dirname "${key_abs}")"

			local prefer_np=0
			if cshell_hybrid_detect_nonprod; then
				prefer_np=1
			elif [[ "${ENVIRONMENT_NAME:-}" =~ [Nn]on[-_]?[Pp]rod ]]; then
				prefer_np=1
			fi

			local eg_slug=""
			if ! eg_slug="$(cshell_hybrid_sanitize_keystore_slug "${ENV_GROUP:-}")"; then
				eg_slug=""
			fi
			local ks_pem_rel="" ks_key_rel="" ks_pem_abs="" ks_key_abs=""
			if [[ -n "${eg_slug}" ]]; then
				ks_pem_rel="certs/keystore_${eg_slug}.pem"
				ks_key_rel="certs/keystore_${eg_slug}.key"
				ks_pem_abs="${vhost}/${ks_pem_rel}"
				ks_key_abs="${vhost}/${ks_key_rel}"
				mkdir -p "$(dirname "${ks_pem_abs}")" "$(dirname "${ks_key_abs}")"
			fi

			info "TLS override paths (sslCertPath / sslKeyPath): ${crt_rel} and ${key_rel}"
			info "Full paths: ${crt_abs} ; ${key_abs}"
			if [[ -n "${ks_pem_abs}" ]]; then
				info "Google quickstart filenames (ENV_GROUP): ${ks_pem_rel} / ${ks_key_rel}"
			elif [[ -z "${ENV_GROUP:-}" ]]; then
				warn "ENV_GROUP is empty — cannot derive keystore_*.pem key names for the quickstart layout."
			fi
			info "Documentation: ${DOC_INSTALL_TLS} (Google Part 2 Step 6; cshell checklist item 7)"

			local generated=0

			# Non-prod: default self-signed at keystore_ENV_GROUP.pem / .key (Google quickstart).
			if [[ "${prefer_np}" == "1" ]] && [[ "${APIGEE_TLS_SKIP_SELF_SIGNED:-0}" != "1" ]]; then
				if [[ -z "${eg_slug}" ]]; then
					warn "ENV_GROUP missing or invalid for keystore file names — skipping automatic self-signed cert."
				elif [[ -z "${DOMAIN:-}" ]]; then
					warn "DOMAIN is empty — skipping automatic self-signed certificate (non-prod)."
				elif ! command_exists openssl; then
					warn "openssl not in PATH — skipping automatic self-signed certificate."
				elif [[ -f "${ks_pem_abs}" && -f "${ks_key_abs}" ]]; then
					info "Keystore files already exist; not overwriting."
				else
					if openssl req -nodes -new -x509 \
						-keyout "${ks_key_abs}" \
						-out "${ks_pem_abs}" \
						-subj "/CN=${DOMAIN}" \
						-days 3650; then
						success "Generated self-signed TLS (Google quickstart layout, CN=${DOMAIN})."
						if cshell_env_upsert_key "${ENV_FILE}" APIGEE_OVERRIDE_TLS_CERT_REL "${ks_pem_rel}" \
							&& cshell_env_upsert_key "${ENV_FILE}" APIGEE_OVERRIDE_TLS_KEY_REL "${ks_key_rel}"; then
							cshell_env_ensure_permissions "${ENV_FILE}"
							export APIGEE_OVERRIDE_TLS_CERT_REL="${ks_pem_rel}"
							export APIGEE_OVERRIDE_TLS_KEY_REL="${ks_key_rel}"
							if declare -F cshell_env_sync_exports >/dev/null 2>&1; then
								cshell_env_sync_exports || warn "Could not refresh shell export snippet."
							fi
						else
							warn "Could not update ${ENV_FILE} with APIGEE_OVERRIDE_TLS_* — set paths manually."
						fi
						generated=1
					else
						warn "openssl failed — add certificate material manually per Google docs."
					fi
				fi
			fi

			# Explicit trial: use APIGEE_OVERRIDE_TLS_* paths (e.g. production-style or custom layout).
			if [[ "${generated}" != "1" ]] && [[ "${APIGEE_TLS_SELF_SIGNED:-0}" == "1" ]]; then
				if [[ -z "${DOMAIN:-}" ]]; then
					warn "APIGEE_TLS_SELF_SIGNED=1 but DOMAIN is empty — skipping openssl."
				elif ! command_exists openssl; then
					warn "openssl not in PATH — cannot generate a self-signed certificate."
				elif [[ -f "${crt_abs}" && -f "${key_abs}" ]]; then
					info "Certificate files already exist at override paths; not overwriting."
				else
					if openssl req -nodes -new -x509 \
						-keyout "${key_abs}" \
						-out "${crt_abs}" \
						-subj "/CN=${DOMAIN}" \
						-days 3650; then
						success "Generated self-signed TLS at override paths (CN=${DOMAIN})."
						generated=1
					else
						warn "openssl failed — add certificate material manually per Google docs."
					fi
				fi
			fi

			if [[ "${generated}" != "1" ]]; then
				if [[ "${prefer_np}" == "1" ]] && [[ "${APIGEE_TLS_SKIP_SELF_SIGNED:-0}" == "1" ]]; then
					info "Non-prod automatic TLS was skipped (APIGEE_TLS_SKIP_SELF_SIGNED=1). Use APIGEE_TLS_SELF_SIGNED=1 to generate at override paths or add certs manually."
				elif [[ "${prefer_np}" == "1" ]]; then
					info "Automatic non-prod TLS not generated; fix DOMAIN, ENV_GROUP, openssl, or use APIGEE_TLS_SKIP_SELF_SIGNED / APIGEE_TLS_SELF_SIGNED as needed."
				else
					info "For production-style installs use CA-signed certs. For a trial on override paths only, set APIGEE_TLS_SELF_SIGNED=1 (${crt_rel} / ${key_rel})."
				fi
			fi
			;;
		8)
			local helm_charts_home="${APIGEE_HELM_CHARTS_HOME}"
			local ov_out="${helm_charts_home}/overrides.yaml"
			local ov_write=1
			if [[ -f "${ov_out}" && -s "${ov_out}" ]]; then
				if [[ "${APIGEE_SETUP_NONINTERACTIVE:-0}" == "1" ]]; then
					if [[ "${APIGEE_OVERRIDES_OVERWRITE:-0}" != "1" ]]; then
						ov_write=0
						warn "Existing overrides.yaml kept (set APIGEE_OVERRIDES_OVERWRITE=1 to replace in non-interactive mode)."
					fi
				else
					if declare -F confirm >/dev/null 2>&1 && ! confirm "Overwrite existing overrides.yaml?" "n"; then
						ov_write=0
						info "Kept existing overrides.yaml."
					fi
				fi
			fi
			if [[ "${ov_write}" != "1" ]]; then
				return 0
			fi
			if [[ -z "${APIGEE_INSTANCE_ID:-}" ]]; then
				error "APIGEE_INSTANCE_ID is missing from ${ENV_FILE}. Run '${SCRIPT_NAME} hybrid' once or use '${SCRIPT_NAME} config set APIGEE_INSTANCE_ID <value>'."
				return 1
			fi
			local apigee_nonprod_sa_secret="${APIGEE_NONPROD_SA_SECRET:-apigee-non-prod-svc-account}"
			local ingress_gateway_name="${APIGEE_INGRESS_NAME:-$(cshell_hybrid_suggest_ingress_name "${ENVIRONMENT_NAME}")}"
			if ! cshell_hybrid_validate_ingress_name "${ingress_gateway_name}"; then
				ingress_gateway_name="apigee-ingress"
			fi
			local override_tls_cert_rel="${APIGEE_OVERRIDE_TLS_CERT_REL:-certs/tls.crt}"
			local override_tls_key_rel="${APIGEE_OVERRIDE_TLS_KEY_REL:-certs/tls.key}"
			local ingress_svc_ann_key="${APIGEE_INGRESS_SVC_ANNOTATION_KEY:-}"
			local ingress_svc_ann_val="${APIGEE_INGRESS_SVC_ANNOTATION_VALUE:-}"
			if [[ -z "${ingress_svc_ann_key}" || -z "${ingress_svc_ann_val}" ]]; then
				ingress_svc_ann_key=""
				ingress_svc_ann_val=""
			fi
			local override_runtime_tag="${APIGEE_OVERRIDE_RUNTIME_TAG:-${CHART_VERSION%%-*}}"
			local override_large_payload="${APIGEE_OVERRIDE_LARGE_PAYLOAD:-0}"
			local control_plane_location="${CONTROL_PLANE_LOCATION:-}"
			# shellcheck disable=SC2153
			if cshell_hybrid_atomic_write_nonprod_overrides "${helm_charts_home}" "1" \
				"${APIGEE_INSTANCE_ID}" "${APIGEE_NAMESPACE}" "${PROJECT_ID}" "${ANALYTICS_REGION}" \
				"${CLUSTER_NAME}" "${CLUSTER_REGION}" "${ORG_NAME}" \
				"${ENVIRONMENT_NAME}" "${ENV_GROUP}" "${control_plane_location}" \
				"${apigee_nonprod_sa_secret}" "${ingress_gateway_name}" \
				"${override_tls_cert_rel}" "${override_tls_key_rel}" "${ingress_svc_ann_key}" "${ingress_svc_ann_val}" \
				"${override_runtime_tag}" "${override_large_payload}"; then
				success "Wrote non-prod ${ov_out}"
			else
				error "Could not write overrides.yaml (is ${helm_charts_home} writable and present?)."
				return 1
			fi
			;;
		9)
			info "Apigee control plane access: ${DOC_INSTALL_CONTROL_PLANE}"
			;;
		10)
			info "cert-manager install: ${DOC_INSTALL_CERT_MANAGER}"
			;;
		11)
			info "Apigee CRDs: ${DOC_INSTALL_CRDS}"
			;;
		12)
			info "Helm install for Hybrid charts: ${DOC_INSTALL_HELM_CHARTS}"
			;;
		13)
			info "Community install guide: ${DOC_INSTALL_HYBRID}"
			;;
		*)
			error "Invalid step number '${n}'."
			return 1
			;;
	esac
	return 0
}

cmd_hybrid_step() {
	local step_num="$1"
	step_num=$((10#${step_num}))
	section "HYBRID" "Apigee Hybrid install — step ${step_num} of 13" "cyan"

	if [[ "${step_num}" -eq 1 ]]; then
		cmd_hybrid_env_file_must_exist || exit 1
		cshell_env_load "${ENV_FILE}"
		cmd_hybrid_env_fill_missing_array
		cmd_hybrid_install_checklist_print 0 0 1 || exit 1
		if [[ "${#hybrid_missing_required[@]}" -gt 0 ]]; then
			cmd_hybrid_env_report_missing_vars
			exit 1
		fi
		cmd_hybrid_run_step_actions 1 || exit 1
		return 0
	fi

	cmd_hybrid_env_validate || exit 1
	cmd_hybrid_env_fill_missing_array
	cmd_hybrid_install_checklist_print 0 0 "${step_num}" || exit 1
	cmd_hybrid_run_step_actions "${step_num}" || exit 1
}

cmd_hybrid_check() {
	local hybrid_strict="${1:-0}"
	local hybrid_json="${2:-0}"

	if [[ "${hybrid_json}" != "1" ]]; then
		section "HYBRID" "Validate Apigee Hybrid environment variables" "cyan"
	fi

	cmd_hybrid_env_file_must_exist || exit 1

	cshell_env_load "${ENV_FILE}"
	cmd_hybrid_env_fill_missing_array
	cmd_hybrid_install_checklist_print "${hybrid_strict}" "${hybrid_json}"

	if [[ "${#hybrid_missing_required[@]}" -gt 0 ]]; then
		cmd_hybrid_env_report_missing_vars
		exit 1
	fi

	if [[ "${hybrid_strict}" == "1" ]] && [[ "${hybrid_checklist_fail_count:-0}" -gt 0 ]]; then
		error "Checklist has ${hybrid_checklist_fail_count} failed item(s) (${HYBRID_CHK_FAIL}). Fix the issues above or run without --strict."
		exit 1
	fi

	if [[ "${hybrid_json}" != "1" ]]; then
		success "All required Hybrid environment variables are set in ${ENV_FILE}."
	fi
}

# Regenerate ~/.cshell-env-exports.sh after validation. Optional --print: stdout is only `export` lines for eval.
cmd_hybrid_export() {
	local print_only="${1:-0}"

	if [[ "${print_only}" != "1" ]]; then
		section "HYBRID" "Sync shell exports for Hybrid variables (~/.cshell-env-exports.sh)" "cyan"
	fi

	cmd_hybrid_env_validate || exit 1

	if [[ "${print_only}" == "1" ]]; then
		if [[ "${BASH_VERSINFO[0]:-0}" -lt 4 ]]; then
			error "bash 4+ required for hybrid --export --print (export snippet uses associative arrays)."
			exit 1
		fi
		if ! cshell_env_write_export_snippet "${ENV_FILE}"; then
			exit 1
		fi
		local exports="${HOME}/.cshell-env-exports.sh"
		if [[ ! -f "${exports}" ]]; then
			error "Export snippet was not created at ${exports}."
			exit 1
		fi
		grep '^export ' "${exports}"
		return 0
	fi

	if ! cshell_env_sync_exports; then
		exit 1
	fi
	success "Hybrid allowlisted variables are in ${HOME}/.cshell-env-exports.sh — new bash sessions load it automatically; this shell: source \"${HOME}/.cshell-env-exports.sh\""
}

cmd_hybrid() {
	if [[ "${1:-}" == "--check" ]]; then
		shift
		local hybrid_strict_mode=0
		local hybrid_json_mode=0
		while (($# > 0)); do
			case "$1" in
				--strict)
					hybrid_strict_mode=1
					shift
					;;
				--json)
					hybrid_json_mode=1
					shift
					;;
				*)
					break
					;;
			esac
		done
		if (($# > 0)); then
			error "Unexpected argument(s): $* — use '${SCRIPT_NAME} hybrid --check [--strict] [--json]'."
			exit 1
		fi
		cmd_hybrid_check "${hybrid_strict_mode}" "${hybrid_json_mode}"
		return
	fi

	if [[ "${1:-}" == "--export" ]]; then
		shift
		local hybrid_export_print=0
		if [[ "${1:-}" == "--print" ]]; then
			shift
			hybrid_export_print=1
		fi
		if (($# > 0)); then
			error "Unexpected argument(s): $* — use '${SCRIPT_NAME} hybrid --export' or '${SCRIPT_NAME} hybrid --export --print'."
			exit 1
		fi
		cmd_hybrid_export "${hybrid_export_print}"
		return
	fi

	if [[ "${1:-}" == "--step" ]]; then
		shift
		local hybrid_step_num="${1:-}"
		shift
		if [[ ! "${hybrid_step_num}" =~ ^[0-9]+$ ]] || ((hybrid_step_num < 1 || hybrid_step_num > 13)); then
			error "hybrid --step requires a number from 1 to 13 (got '${hybrid_step_num:-}')."
			exit 1
		fi
		if (($# > 0)); then
			error "Unexpected argument(s): $* — use '${SCRIPT_NAME} hybrid --step <1-13>'."
			exit 1
		fi
		cmd_hybrid_step "${hybrid_step_num}"
		return
	fi

	section "HYBRID" "Apigee Hybrid v1.16 setup" "cyan"

	# ── Documentation links ──────────────────────────────────────────────────
	info "Relevant documentation:"
	bullet_list \
		"Project README: ${DOC_PROJECT_README}" \
		"Releases: ${DOC_PROJECT_RELEASES}" \
		"Issues: ${DOC_PROJECT_ISSUES}" \
		"Contributing: ${DOC_PROJECT_CONTRIBUTING}" \
		"Google Hybrid v1.16 — Before you begin: ${DOC_BEFORE_BEGIN}" \
		"Google — Create cluster: ${DOC_INSTALL_CREATE_CLUSTER}" \
		"Google — Download charts: ${DOC_DOWNLOAD_CHARTS}" \
		"Google — Create namespace: ${DOC_INSTALL_CREATE_NAMESPACE}" \
		"Google — Service accounts: ${DOC_INSTALL_SERVICE_ACCOUNTS}" \
		"Google — Service account auth: ${DOC_INSTALL_SA_AUTH}" \
		"Google — TLS certificates: ${DOC_INSTALL_TLS}" \
		"Google — Overrides: ${DOC_INSTALL_OVERRIDES}" \
		"Google — Control plane access: ${DOC_INSTALL_CONTROL_PLANE}" \
		"Google — cert-manager: ${DOC_INSTALL_CERT_MANAGER}" \
		"Google — CRDs: ${DOC_INSTALL_CRDS}" \
		"Google — Helm install: ${DOC_INSTALL_HELM_CHARTS}" \
		"Community install guide: ${DOC_INSTALL_HYBRID}"

	# ── 1. Interactive environment variables ─────────────────────────────────
	section "ENV" "Apigee Hybrid environment variables" "blue"
	info "Values will be written to ${ENV_FILE}"

	# Load existing values if present
	if [[ -f "${ENV_FILE}" ]]; then
		cshell_env_load "${ENV_FILE}"
	fi

	local project_id org_name org_display_name org_description \
		analytics_region runtime_type helm_charts_home \
		cluster_name cluster_region aks_resource_group apigee_namespace environment_name \
		env_group env_group_release_name domain control_plane_location

	project_id=$(ask "GCP Project ID" "${PROJECT_ID:-}")
	org_name=$(ask "Apigee Organization name" "${ORG_NAME:-$project_id}")
	org_display_name=$(ask "Apigee Organization display name" "${ORG_DISPLAY_NAME:-$org_name}")
	org_description=$(ask "Apigee Organization description" "${ORGANIZATION_DESCRIPTION:-Apigee Hybrid organization}")
	analytics_region=$(ask "Analytics region (e.g. europe-west3)" "${ANALYTICS_REGION:-europe-west3}")
	runtime_type=$(ask "Runtime type" "${RUNTIMETYPE:-HYBRID}")
	cluster_name=$(ask "Kubernetes cluster name" "${CLUSTER_NAME:-aks-hybrid}")
	cluster_region=$(ask "Kubernetes cluster region (maps to CLUSTER_LOCATION in Google docs)" "${CLUSTER_REGION:-${analytics_region}}")
	aks_resource_group=$(ask "Azure AKS resource group (for az aks get-credentials; leave empty to skip)" "${AKS_RESOURCE_GROUP:-}")
	aks_resource_group="${aks_resource_group#"${aks_resource_group%%[![:space:]]*}"}"
	aks_resource_group="${aks_resource_group%"${aks_resource_group##*[![:space:]]}"}"
	helm_charts_home=$(ask "Local Helm charts directory" "${APIGEE_HELM_CHARTS_HOME:-${DEFAULT_APIGEE_HELM_CHARTS_HOME}}")
	helm_charts_home="${helm_charts_home#"${helm_charts_home%%[![:space:]]*}"}"
	helm_charts_home="${helm_charts_home%"${helm_charts_home##*[![:space:]]}"}"
	if [[ -z "${helm_charts_home}" ]]; then
		helm_charts_home="${DEFAULT_APIGEE_HELM_CHARTS_HOME}"
	fi
	mkdir -p "${helm_charts_home}"
	helm_charts_home="$(cshell_realpath "${helm_charts_home}" 2>/dev/null || printf '%s\n' "${helm_charts_home}")"

	apigee_namespace=$(ask "Kubernetes namespace for Apigee pods" "${APIGEE_NAMESPACE:-apigee}")
	environment_name=$(ask "Apigee environment name (must match UI; non-prod often pairs with apigee-non-prod SA)" "${ENVIRONMENT_NAME:-non-prod}")
	env_group=$(ask "Apigee environment group name (Helm --set envgroup)" "${ENV_GROUP:-envgroup}")
	env_group_release_name=$(ask "Helm release name for apigee-virtualhost (unique per cluster)" "${ENV_GROUP_RELEASE_NAME:-apigee-virtualhost}")
	domain=$(ask "Public hostname for the environment group (TLS / virtual host CN)" "${DOMAIN:-}")
	control_plane_location=$(ask "Control plane location (optional; only needed for data residency)" "${CONTROL_PLANE_LOCATION:-}")

	local apigee_instance_id apigee_nonprod_sa_secret ingress_gateway_name \
		override_tls_cert_rel override_tls_key_rel ingress_svc_ann_key ingress_svc_ann_val \
		override_runtime_tag override_large_payload

	section "OVERRIDES" "Non-prod overrides.yaml (Kubernetes Secrets)" "blue"
	info "Values are merged into ${ENV_FILE} when set; file is written after Helm charts are pulled."

	local _id_default
	_id_default="$(cshell_hybrid_suggest_instance_id "${org_name}" "${cluster_name}")"
	apigee_instance_id=$(ask "Apigee hybrid instanceID (unique per cluster; max 63 chars)" "${APIGEE_INSTANCE_ID:-${_id_default}}")
	apigee_nonprod_sa_secret=$(ask "Kubernetes secret name for non-prod service account" "${APIGEE_NONPROD_SA_SECRET:-apigee-non-prod-svc-account}")
	ingress_gateway_name=$(ask "Ingress gateway name (max 17 chars, lowercase)" "${APIGEE_INGRESS_NAME:-$(cshell_hybrid_suggest_ingress_name "${environment_name}")}")
	if ! cshell_hybrid_validate_ingress_name "${ingress_gateway_name}"; then
		warn "Ingress name '${ingress_gateway_name}' is invalid — using 'apigee-ingress'."
		ingress_gateway_name="apigee-ingress"
	fi
	override_tls_cert_rel=$(ask "Virtual host sslCertPath (relative to apigee-virtualhost chart)" "${APIGEE_OVERRIDE_TLS_CERT_REL:-certs/tls.crt}")
	override_tls_key_rel=$(ask "Virtual host sslKeyPath (relative to apigee-virtualhost chart)" "${APIGEE_OVERRIDE_TLS_KEY_REL:-certs/tls.key}")
	ingress_svc_ann_key=$(ask "Ingress LoadBalancer annotation key (optional; empty to skip)" "${APIGEE_INGRESS_SVC_ANNOTATION_KEY:-}")
	ingress_svc_ann_val=$(ask "Ingress LoadBalancer annotation value (optional)" "${APIGEE_INGRESS_SVC_ANNOTATION_VALUE:-}")
	if [[ -z "${ingress_svc_ann_key}" || -z "${ingress_svc_ann_val}" ]]; then
		ingress_svc_ann_key=""
		ingress_svc_ann_val=""
	fi
	local _rt_default="${CHART_VERSION%%-*}"
	override_runtime_tag=$(ask "apigee-runtime image tag (see Apigee release matrix)" "${APIGEE_OVERRIDE_RUNTIME_TAG:-${_rt_default}}")
	if [[ "${APIGEE_SETUP_NONINTERACTIVE:-0}" == "1" ]]; then
		override_large_payload="${APIGEE_OVERRIDE_LARGE_PAYLOAD:-0}"
	elif declare -F confirm >/dev/null 2>&1; then
		local lp_def="n"
		[[ "${APIGEE_OVERRIDE_LARGE_PAYLOAD:-0}" == "1" ]] && lp_def="y"
		if confirm "Add large message payload tuning (runtime heap/resources for payloads >10MB)?" "${lp_def}"; then
			override_large_payload=1
		else
			override_large_payload=0
		fi
	else
		[[ "${APIGEE_OVERRIDE_LARGE_PAYLOAD:-0}" == "1" ]] && override_large_payload=1 || override_large_payload=0
	fi

	if [[ "${APIGEE_SETUP_NONINTERACTIVE:-0}" == "1" ]]; then
		if [[ -z "${project_id}" ]]; then
			error "APIGEE_SETUP_NONINTERACTIVE: PROJECT_ID must be set (e.g. in ${ENV_FILE} or the environment) before running hybrid."
			exit 1
		fi
		if [[ -z "${domain}" ]]; then
			warn "APIGEE_SETUP_NONINTERACTIVE: DOMAIN is empty — set DOMAIN for TLS / virtual host steps."
		fi
	fi

	touch "${ENV_FILE}"
	cshell_env_strip_managed_block "${ENV_FILE}" "# BEGIN_CSHELL_HYBRID_ENV" "# END_CSHELL_HYBRID_ENV"

	# Persist hybrid block only; other ~/.cshell.env keys (Azure, etc.) are preserved.
	{
		echo "# BEGIN_CSHELL_HYBRID_ENV"
		echo "# Apigee Hybrid – environment variables"
		echo "# Generated by cshell on $(date -u +"%Y-%m-%dT%H:%M:%SZ")"
		printf 'PROJECT_ID=%s\n' "${project_id}"
		printf 'ORG_NAME=%s\n' "${org_name}"
		printf 'ORG_DISPLAY_NAME=%s\n' "${org_display_name}"
		printf 'ORGANIZATION_DESCRIPTION=%s\n' "${org_description}"
		printf 'ANALYTICS_REGION=%s\n' "${analytics_region}"
		printf 'RUNTIMETYPE=%s\n' "${runtime_type}"
		printf 'CLUSTER_NAME=%s\n' "${cluster_name}"
		printf 'CLUSTER_REGION=%s\n' "${cluster_region}"
		if [[ -n "${aks_resource_group}" ]]; then
			printf 'AKS_RESOURCE_GROUP=%s\n' "${aks_resource_group}"
		fi
		printf 'APIGEE_NAMESPACE=%s\n' "${apigee_namespace}"
		printf 'ENVIRONMENT_NAME=%s\n' "${environment_name}"
		printf 'ENV_GROUP=%s\n' "${env_group}"
		printf 'ENV_GROUP_RELEASE_NAME=%s\n' "${env_group_release_name}"
		printf 'DOMAIN=%s\n' "${domain}"
		if [[ -n "${control_plane_location}" ]]; then
			printf 'CONTROL_PLANE_LOCATION=%s\n' "${control_plane_location}"
		fi
		printf 'APIGEE_HELM_CHARTS_HOME=%s\n' "${helm_charts_home}"
		printf 'CHART_REPO=%s\n' "${CHART_REPO}"
		printf 'CHART_VERSION=%s\n' "${CHART_VERSION}"
		printf 'APIGEE_INSTANCE_ID=%s\n' "${apigee_instance_id}"
		printf 'APIGEE_NONPROD_SA_SECRET=%s\n' "${apigee_nonprod_sa_secret}"
		printf 'APIGEE_INGRESS_NAME=%s\n' "${ingress_gateway_name}"
		printf 'APIGEE_OVERRIDE_TLS_CERT_REL=%s\n' "${override_tls_cert_rel}"
		printf 'APIGEE_OVERRIDE_TLS_KEY_REL=%s\n' "${override_tls_key_rel}"
		if [[ -n "${ingress_svc_ann_key}" ]]; then
			printf 'APIGEE_INGRESS_SVC_ANNOTATION_KEY=%s\n' "${ingress_svc_ann_key}"
			printf 'APIGEE_INGRESS_SVC_ANNOTATION_VALUE=%s\n' "${ingress_svc_ann_val}"
		fi
		printf 'APIGEE_OVERRIDE_RUNTIME_TAG=%s\n' "${override_runtime_tag}"
		printf 'APIGEE_OVERRIDE_LARGE_PAYLOAD=%s\n' "${override_large_payload}"
		echo "# END_CSHELL_HYBRID_ENV"
	} >>"${ENV_FILE}"

	cshell_env_ensure_permissions "${ENV_FILE}"

	if command_exists bash; then
		cshell_env_sync_exports || warn "Could not refresh shell export snippet (bash 4+ required for ~/.cshell-env-exports.sh)."
	else
		warn "bash not found; Hybrid values are in ${ENV_FILE} only."
	fi

	success "Environment variables written to ${ENV_FILE}"
	info "Use '${SCRIPT_NAME} config show' to inspect values (avoid sourcing ${ENV_FILE} unless you trust every line)."
	echo ""

	# ── 2. Download Helm charts ───────────────────────────────────────────────
	if ! cmd_hybrid_pull_apigee_charts "${helm_charts_home}"; then
		exit 1
	fi

	local ov_out="${helm_charts_home}/overrides.yaml"
	local ov_write=1
	if [[ -f "${ov_out}" && -s "${ov_out}" ]]; then
		if [[ "${APIGEE_SETUP_NONINTERACTIVE:-0}" == "1" ]]; then
			if [[ "${APIGEE_OVERRIDES_OVERWRITE:-0}" != "1" ]]; then
				ov_write=0
				warn "Existing overrides.yaml kept (set APIGEE_OVERRIDES_OVERWRITE=1 to replace in non-interactive mode)."
			fi
		else
			if declare -F confirm >/dev/null 2>&1 && ! confirm "Overwrite existing overrides.yaml?" "n"; then
				ov_write=0
				info "Kept existing overrides.yaml."
			fi
		fi
	fi
	if [[ "${ov_write}" == "1" ]]; then
		if cshell_hybrid_atomic_write_nonprod_overrides "${helm_charts_home}" "1" \
			"${apigee_instance_id}" "${apigee_namespace}" "${project_id}" "${analytics_region}" \
			"${cluster_name}" "${cluster_region}" "${org_name}" \
			"${environment_name}" "${env_group}" "${control_plane_location}" \
			"${apigee_nonprod_sa_secret}" "${ingress_gateway_name}" \
			"${override_tls_cert_rel}" "${override_tls_key_rel}" "${ingress_svc_ann_key}" "${ingress_svc_ann_val}" \
			"${override_runtime_tag}" "${override_large_payload}"; then
			success "Wrote non-prod ${ov_out}"
		else
			warn "Could not write overrides.yaml (charts directory missing?)."
		fi
	fi

	cshell_hybrid_fetch_aks_kubeconfig "${aks_resource_group}" "${cluster_name}"
}

