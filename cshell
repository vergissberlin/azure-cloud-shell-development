# ---------------------------------------------------------------------------
# init – create Azure Storage Account and container
# ---------------------------------------------------------------------------

cmd_init() {
	section "INIT" "Create Azure Storage Account resources" "cyan"

	if ! command_exists az; then
		error "Azure CLI (az) is not installed or not in PATH."
		exit 1
	fi

	# Load existing env values as defaults (if available)
	if [[ -f "${ENV_FILE}" ]]; then
		cshell_env_load "${ENV_FILE}"
	fi

	local subscription resource_group location storage_account container_name sku access_tier allow_cross_tenant_replication storage_account_key

	subscription=$(ask "Azure Subscription ID or name (leave blank to use current)" "${AZURE_SUBSCRIPTION:-}")
	resource_group=$(ask "Resource group name" "${AZURE_RESOURCE_GROUP:-rg-cshell}")
	location=$(ask "Azure region (e.g. germanywestcentral)" "${AZURE_LOCATION:-germanywestcentral}")
	storage_account=$(ask "Storage Account name (3-24 lowercase letters/digits)" "${AZURE_STORAGE_ACCOUNT:-}")
	container_name=$(ask "Blob container name" "${AZURE_STORAGE_CONTAINER:-backups}")
	sku=$(ask "Storage SKU (cheap default: Standard_LRS)" "${AZURE_STORAGE_SKU:-Standard_LRS}")
	access_tier=$(ask "Storage access tier (Hot/Cool, cheap default: Cool)" "${AZURE_STORAGE_ACCESS_TIER:-Cool}")
	allow_cross_tenant_replication=$(ask "Allow cross-tenant replication? (true/false)" "${AZURE_STORAGE_ALLOW_CROSS_TENANT_REPLICATION:-false}")

	# ── Set subscription ────────────────────────────────────────────────────
	if [[ -n "${subscription}" ]]; then
		info "Setting active subscription to '${subscription}' ..."
		az account set --subscription "${subscription}"
		success "Subscription set"
	fi

	# ── Create resource group if it does not exist ───────────────────────────
	if az group show --name "${resource_group}" &>/dev/null; then
		success "Resource group '${resource_group}' already exists"
	else
		info "Creating resource group '${resource_group}' in '${location}' ..."
		az group create \
			--name "${resource_group}" \
			--location "${location}" \
			--output none
		success "Resource group '${resource_group}' created"
	fi

	# ── Create Storage Account if it does not exist ──────────────────────────
	if az storage account show \
		--name "${storage_account}" \
		--resource-group "${resource_group}" &>/dev/null; then
		success "Storage Account '${storage_account}' already exists"
	else
		info "Creating Storage Account '${storage_account}' (${sku}, accessTier=${access_tier}, allowCrossTenantReplication=${allow_cross_tenant_replication}) ..."
		az storage account create \
			--name "${storage_account}" \
			--resource-group "${resource_group}" \
			--location "${location}" \
			--sku "${sku}" \
			--access-tier "${access_tier}" \
			--kind StorageV2 \
			--allow-cross-tenant-replication "${allow_cross_tenant_replication}" \
			--output none
		success "Storage Account '${storage_account}' created"
	fi

	# ── Create Blob container if it does not exist ───────────────────────────
	if az storage container exists \
		--name "${container_name}" \
		--account-name "${storage_account}" \
		--auth-mode login \
		--query "exists" \
		--output tsv 2>/dev/null | grep -q "^true$"; then
		success "Blob container '${container_name}' already exists"
	else
		info "Creating blob container '${container_name}' ..."
		az storage container create \
			--name "${container_name}" \
			--account-name "${storage_account}" \
			--auth-mode login \
			--output none
		success "Blob container '${container_name}' created"
	fi

	# ── Try to resolve account key for auth fallback ───────────────────────────
	storage_account_key="${AZURE_STORAGE_ACCOUNT_KEY:-}"
	if [[ -z "${storage_account_key}" ]]; then
		info "Trying to resolve storage account key for fallback auth ..."
		storage_account_key="$(
			az storage account keys list \
				--resource-group "${resource_group}" \
				--account-name "${storage_account}" \
				--query "[0].value" \
				--output tsv 2>/dev/null || true
		)"
		if [[ -n "${storage_account_key}" ]]; then
			success "Storage account key resolved and will be saved to ${ENV_FILE}"
		else
			warn "Could not resolve storage account key automatically."
			warn "You can set AZURE_STORAGE_ACCOUNT_KEY manually in ${ENV_FILE}."
		fi
	fi

	# ── Persist config to env file (remove any previous cshell init block) ───
	if [[ -f "${ENV_FILE}" ]]; then
		cshell_env_strip_managed_block "${ENV_FILE}" "# BEGIN_CSHELL_INIT" "# END_CSHELL_INIT"
		portable_sed_i '/^# Azure Storage – written by cshell init/,/^AZURE_STORAGE_ALLOW_CROSS_TENANT_REPLICATION=/d' "${ENV_FILE}"
	fi

	{
		echo ""
		echo "# BEGIN_CSHELL_INIT"
		echo "# Azure Storage – written by cshell init on $(date -u +"%Y-%m-%dT%H:%M:%SZ")"
		printf 'AZURE_SUBSCRIPTION=%s\n' "${subscription}"
		printf 'AZURE_RESOURCE_GROUP=%s\n' "${resource_group}"
		printf 'AZURE_LOCATION=%s\n' "${location}"
		printf 'AZURE_STORAGE_ACCOUNT=%s\n' "${storage_account}"
		printf 'AZURE_STORAGE_CONTAINER=%s\n' "${container_name}"
		if [[ -n "${storage_account_key}" ]]; then
			printf 'AZURE_STORAGE_ACCOUNT_KEY=%s\n' "${storage_account_key}"
		fi
		printf 'AZURE_STORAGE_SKU=%s\n' "${sku}"
		printf 'AZURE_STORAGE_ACCESS_TIER=%s\n' "${access_tier}"
		printf 'AZURE_STORAGE_ALLOW_CROSS_TENANT_REPLICATION=%s\n' "${allow_cross_tenant_replication}"
		echo "# END_CSHELL_INIT"
	} >>"${ENV_FILE}"

	cshell_env_ensure_permissions "${ENV_FILE}"

	if command_exists bash; then
		cshell_env_sync_exports || warn "Could not refresh shell export snippet (bash 4+ required for ~/.cshell-env-exports.sh)."
	fi

	success "Configuration saved to ${ENV_FILE}"
	info "Run 'cshell backup' to create and upload your first backup."
}

# ---------------------------------------------------------------------------
# backup
# ---------------------------------------------------------------------------

cmd_backup() {
	local dry_run=0 verbose=0
	while [[ $# -gt 0 ]]; do
		case "$1" in
			-n | --dry-run)
				dry_run=1
				shift
				;;
			-v | --verbose)
				verbose=1
				shift
				;;
			*)
				warn "Unknown option for backup: $1"
				exit 1
				;;
		esac
	done

	section "BACKUP" "Backup home directory" "cyan"

	if [[ "${dry_run}" -eq 1 ]]; then
		info "[dry-run] Would create ${ARCHIVE_FILE} from ${HOME} (excluding .cache, gcloud logs, archive.zip)."
		if [[ -f "${ENV_FILE}" ]]; then
			cshell_env_load "${ENV_FILE}"
		fi
		if [[ -n "${AZURE_STORAGE_ACCOUNT:-}" && -n "${AZURE_STORAGE_CONTAINER:-}" ]]; then
			info "[dry-run] Would upload ${ARCHIVE_FILE} to blob container '${AZURE_STORAGE_CONTAINER}' (account ${AZURE_STORAGE_ACCOUNT})."
		else
			info "[dry-run] No Azure storage config; would skip upload."
		fi
		return 0
	fi

	info "Creating archive: ${ARCHIVE_FILE}"
	[[ "${verbose}" -eq 1 ]] && info "zip excludes: .cache/*, .config/google-cloud-sdk/logs/*, archive.zip"
	(cd "${HOME}" && zip -r "${ARCHIVE_FILE}" . \
		--exclude ".cache/*" \
		--exclude ".config/google-cloud-sdk/logs/*" \
		--exclude "archive.zip")

	success "Backup created: ${ARCHIVE_FILE}"

	# Optional: upload to Azure Blob Storage
	if [[ -f "${ENV_FILE}" ]]; then
		cshell_env_load "${ENV_FILE}"
	fi

	if [[ -n "${AZURE_STORAGE_ACCOUNT:-}" && -n "${AZURE_STORAGE_CONTAINER:-}" ]]; then
		info "Uploading archive to Azure Blob Storage ..."
		if upload_blob_with_fallback \
			"${AZURE_STORAGE_ACCOUNT}" \
			"${AZURE_STORAGE_CONTAINER}" \
			"archive.zip" \
			"${ARCHIVE_FILE}"; then
			success "Archive uploaded to Azure Blob Storage"
			info "  Account  : ${AZURE_STORAGE_ACCOUNT}"
			info "  Container: ${AZURE_STORAGE_CONTAINER}"
		else
			warn "Backup archive exists locally but upload failed."
			warn "Grant one role like 'Storage Blob Data Contributor' on the storage account,"
			warn "or set AZURE_STORAGE_ACCOUNT_KEY in ${ENV_FILE} for key-based fallback."
		fi
	else
		warn "No Azure storage config found. Skipping upload."
		warn "Run 'cshell setup' to configure Azure Blob Storage."
	fi
}

# ---------------------------------------------------------------------------
# restore
# ---------------------------------------------------------------------------

cmd_restore() {
	local dry_run=0 verbose=0
	while [[ $# -gt 0 ]]; do
		case "$1" in
			-n | --dry-run)
				dry_run=1
				shift
				;;
			-v | --verbose)
				verbose=1
				shift
				;;
			*)
				warn "Unknown option for restore: $1"
				exit 1
				;;
		esac
	done

	section "RESTORE" "Restore home directory" "cyan"

	# Optionally download archive from Azure Blob Storage first
	if [[ -f "${ENV_FILE}" ]]; then
		cshell_env_load "${ENV_FILE}"
	fi

	if [[ ! -f "${ARCHIVE_FILE}" ]]; then
		if [[ -n "${AZURE_STORAGE_ACCOUNT:-}" && -n "${AZURE_STORAGE_CONTAINER:-}" ]]; then
			if [[ "${dry_run}" -eq 1 ]]; then
				info "[dry-run] Would download archive.zip from Azure Blob Storage to ${ARCHIVE_FILE}."
				return 0
			fi
			info "Local archive not found. Downloading from Azure Blob Storage ..."
			if download_blob_with_fallback \
				"${AZURE_STORAGE_ACCOUNT}" \
				"${AZURE_STORAGE_CONTAINER}" \
				"archive.zip" \
				"${ARCHIVE_FILE}"; then
				success "Archive downloaded from Azure Blob Storage"
			else
				error "Could not download archive from Azure Blob Storage."
				error "Grant blob data permissions or set AZURE_STORAGE_ACCOUNT_KEY in ${ENV_FILE}."
				exit 1
			fi
		else
			error "Archive not found at ${ARCHIVE_FILE}, and no Azure storage config is available."
			warn "Place archive.zip in your home directory or run 'cshell setup' to configure Azure."
			exit 1
		fi
	fi

	if [[ "${dry_run}" -eq 1 ]]; then
		info "[dry-run] Would unzip ${ARCHIVE_FILE} into ${HOME} (overwriting files)."
		[[ "${verbose}" -eq 1 ]] && info "[dry-run] Target exists: $([[ -f "${ARCHIVE_FILE}" ]] && echo yes || echo no)"
		return 0
	fi

	info "Restoring from ${ARCHIVE_FILE} into ${HOME} ..."
	[[ "${verbose}" -eq 1 ]] && info "Running: unzip -o ${ARCHIVE_FILE}"
	(cd "${HOME}" && unzip -o "${ARCHIVE_FILE}")
	success "Restore completed from ${ARCHIVE_FILE}"
}

cmd_update() {
	section "UPDATE" "Update ${SCRIPT_NAME} to latest release" "cyan"

	if ! command_exists curl; then
		error "curl is required for update but not installed."
		exit 1
	fi

	local latest_tag release_ref target_path target_dir raw_url tmp_file installed_version verified=0

	latest_tag="$(resolve_latest_release_tag || true)"
	release_ref="${latest_tag:-${DEFAULT_REF}}"
	target_path="$(resolve_update_target_path)"
	target_dir="$(dirname "${target_path}")"

	mkdir -p "${target_dir}"

	if [[ -n "${latest_tag}" ]]; then
		info "Updating ${SCRIPT_NAME} to ${latest_tag} (verifying release tarball when available) ..."
		if download_and_install_verified_release "${latest_tag}" "${target_path}"; then
			verified=1
		else
			warn "Verified release install unavailable (missing python3/sha256sum, assets, or checksum mismatch). Falling back to raw download."
		fi
	else
		warn "Could not resolve latest release tag. Falling back to ${DEFAULT_REF}."
		info "Updating ${SCRIPT_NAME} from ${DEFAULT_REF} branch ..."
	fi

	if [[ "${verified}" -eq 0 ]]; then
		raw_url="https://raw.githubusercontent.com/${REPO_SLUG}/${release_ref}/${SCRIPT_NAME}"
		tmp_file="$(mktemp "${target_dir}/${SCRIPT_NAME}.XXXXXX")"
		info "Download source: ${raw_url}"
		if ! curl_github "${raw_url}" -o "${tmp_file}"; then
			rm -f "${tmp_file}"
			error "Download failed. ${SCRIPT_NAME} was not changed."
			exit 1
		fi
		info "Downloading ${SCRIPT_NAME} library files (raw install) ..."
		if ! download_cshell_support_libs_from_raw "${release_ref}" "${target_dir}"; then
			rm -f "${tmp_file}"
			error "Library download failed. ${SCRIPT_NAME} was not changed."
			exit 1
		fi
		chmod +x "${tmp_file}"
		mv "${tmp_file}" "${target_path}"
	fi

	success "${SCRIPT_NAME} updated at ${target_path}"

	installed_version="$("${target_path}" --version 2>/dev/null || true)"
	if [[ -n "${installed_version}" ]]; then
		info "Installed version: ${installed_version}"
	else
		warn "Installed version could not be detected with '${target_path} --version'."
	fi
}

