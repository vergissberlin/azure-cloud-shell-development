#!/usr/bin/env bash
# cshell – Azure Cloud Shell development helper
# Subcommands: setup | hybrid | backup | restore

set -euo pipefail

SCRIPT_NAME="cshell"
INSTALL_PATH_DEFAULT="/usr/bin/${SCRIPT_NAME}"
INSTALL_PATH_USER="${HOME}/.local/bin/${SCRIPT_NAME}"
ENV_FILE="${HOME}/.cshell.env"
ARCHIVE_FILE="${HOME}/archive.zip"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLI_UTILS_PATH="${SCRIPT_DIR}/scripts/misc-cli-utils.sh"

CHART_REPO="oci://us-docker.pkg.dev/apigee-release/apigee-hybrid-helm-charts"
CHART_VERSION="1.16.0-hotfix.1"
APIGEE_CHARTS=(
  apigee-operator
  apigee-datastore
  apigee-env
  apigee-ingress-manager
  apigee-org
  apigee-redis
  apigee-telemetry
  apigee-virtualhost
)

DOC_BEFORE_BEGIN="https://docs.cloud.google.com/apigee/docs/hybrid/v1.16/install-before-begin"
DOC_DOWNLOAD_CHARTS="https://docs.cloud.google.com/apigee/docs/hybrid/v1.16/install-download-charts"
DOC_INSTALL_HYBRID="https://github.com/vergissberlin/apigee-hybride-development/blob/main/docs/install-apigee-hybrid.md"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

if [[ -f "${CLI_UTILS_PATH}" ]]; then
  # shellcheck source=/dev/null
  source "${CLI_UTILS_PATH}"
fi

# Fallback for globally installed script where shared utils are unavailable.
if ! declare -F info >/dev/null 2>&1; then
  info()    { echo -e "\033[1;34m[INFO]\033[0m  $*"; }
  success() { echo -e "\033[1;32m[OK]\033[0m    $*"; }
  warn()    { echo -e "\033[1;33m[WARN]\033[0m  $*"; }
  error()   { echo -e "\033[1;31m[ERROR]\033[0m $*" >&2; }
fi

ask() {
  local prompt="$1"
  local default="${2:-}"
  local value
  if [[ -n "$default" ]]; then
    read -rp "${prompt} [${default}]: " value
    echo "${value:-$default}"
  else
    read -rp "${prompt}: " value
    echo "$value"
  fi
}

require_root() {
  if [[ $EUID -ne 0 ]]; then
    error "This step requires root privileges. Please run with sudo."
    exit 1
  fi
}

command_exists() {
  command -v "$1" &>/dev/null
}

upload_blob_with_fallback() {
  local account_name="$1"
  local container_name="$2"
  local blob_name="$3"
  local file_path="$4"
  local cmd_output

  if cmd_output=$(az storage blob upload \
    --account-name "${account_name}" \
    --container-name "${container_name}" \
    --name "${blob_name}" \
    --file "${file_path}" \
    --auth-mode login \
    --only-show-errors 2>&1); then
    return 0
  fi

  warn "Upload with Azure AD login failed. Trying account key from ${ENV_FILE} ..."
  if [[ -n "${AZURE_STORAGE_ACCOUNT_KEY:-}" ]]; then
    if cmd_output=$(az storage blob upload \
      --account-name "${account_name}" \
      --container-name "${container_name}" \
      --name "${blob_name}" \
      --file "${file_path}" \
      --auth-mode key \
      --account-key "${AZURE_STORAGE_ACCOUNT_KEY}" \
      --only-show-errors 2>&1); then
      return 0
    fi
    warn "Upload with account key also failed."
    warn "${cmd_output}"
    return 1
  fi

  warn "${cmd_output}"
  warn "No AZURE_STORAGE_ACCOUNT_KEY set in ${ENV_FILE}."
  return 1
}

download_blob_with_fallback() {
  local account_name="$1"
  local container_name="$2"
  local blob_name="$3"
  local file_path="$4"
  local cmd_output

  if cmd_output=$(az storage blob download \
    --account-name "${account_name}" \
    --container-name "${container_name}" \
    --name "${blob_name}" \
    --file "${file_path}" \
    --auth-mode login \
    --only-show-errors 2>&1); then
    return 0
  fi

  warn "Download with Azure AD login failed. Trying account key from ${ENV_FILE} ..."
  if [[ -n "${AZURE_STORAGE_ACCOUNT_KEY:-}" ]]; then
    if cmd_output=$(az storage blob download \
      --account-name "${account_name}" \
      --container-name "${container_name}" \
      --name "${blob_name}" \
      --file "${file_path}" \
      --auth-mode key \
      --account-key "${AZURE_STORAGE_ACCOUNT_KEY}" \
      --only-show-errors 2>&1); then
      return 0
    fi
    warn "Download with account key also failed."
    warn "${cmd_output}"
    return 1
  fi

  warn "${cmd_output}"
  warn "No AZURE_STORAGE_ACCOUNT_KEY set in ${ENV_FILE}."
  return 1
}

# ---------------------------------------------------------------------------
# setup
# ---------------------------------------------------------------------------

cmd_setup() {
  if declare -F section >/dev/null 2>&1; then
    section "SETUP" "cshell setup workflow" "cyan"
  else
    info "=== cshell setup ==="
  fi

  # ── 1. Install cshell binary ──────────────────────────────────────────────
  local install_path
  if [[ $EUID -eq 0 ]]; then
    install_path="${INSTALL_PATH_DEFAULT}"
  else
    install_path="${INSTALL_PATH_USER}"
    mkdir -p "$(dirname "${install_path}")"
  fi

  info "Installing ${SCRIPT_NAME} to ${install_path} ..."
  cp "$(realpath "$0")" "${install_path}"
  chmod +x "${install_path}"
  success "cshell installed to ${install_path}"
  if [[ "${install_path}" == "${INSTALL_PATH_USER}" ]]; then
    if [[ ":${PATH}:" != *":${HOME}/.local/bin:"* ]]; then
      warn "${HOME}/.local/bin is not in PATH. Add this to your shell profile:"
      echo '  export PATH="$HOME/.local/bin:$PATH"'
    fi
  fi

  # ── 2. Install gcloud CLI (Apigee hybrid development) ────────────────────
  if command_exists gcloud; then
    success "gcloud is already installed ($(gcloud --version 2>&1 | head -1))"
  else
    info "Installing Google Cloud SDK ..."
    if command_exists apt-get; then
      apt-get update -qq
      apt-get install -y ca-certificates gnupg curl
      echo "deb [signed-by=/usr/share/keyrings/cloud.google.gpg] \
https://packages.cloud.google.com/apt cloud-sdk main" \
        | tee /etc/apt/sources.list.d/google-cloud-sdk.list
      curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg \
        | gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg
      apt-get update -qq
      apt-get install -y google-cloud-cli
    elif command_exists brew; then
      brew install --cask google-cloud-sdk
    else
      info "No apt/brew found. Using official tarball installer ..."
      local tmp_dir gcloud_tar gcloud_root gcloud_bin target_bin os arch
      tmp_dir="$(mktemp -d)"
      os="$(uname -s | tr '[:upper:]' '[:lower:]')"
      arch="$(uname -m)"
      case "${arch}" in
        x86_64|amd64) arch="x86_64" ;;
        aarch64|arm64) arch="arm" ;;
        *)
          error "Unsupported architecture for gcloud installer: ${arch}"
          exit 1
          ;;
      esac
      gcloud_tar="${tmp_dir}/google-cloud-cli.tar.gz"
      curl -fsSL "https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-cli-${os}-${arch}.tar.gz" -o "${gcloud_tar}"
      tar -xzf "${gcloud_tar}" -C "${tmp_dir}"
      gcloud_root="${tmp_dir}/google-cloud-sdk"
      "${gcloud_root}/install.sh" --quiet --path-update=true --usage-reporting=false --command-completion=true
      gcloud_bin="${gcloud_root}/bin/gcloud"
      if [[ -x "${gcloud_bin}" ]]; then
        if [[ $EUID -eq 0 ]]; then
          target_bin="/usr/local/bin/gcloud"
        else
          mkdir -p "${HOME}/.local/bin"
          target_bin="${HOME}/.local/bin/gcloud"
        fi
        cp "${gcloud_bin}" "${target_bin}"
        chmod +x "${target_bin}"
      else
        error "gcloud binary not found after installer run."
        exit 1
      fi
    fi
    success "gcloud installed"
  fi

  # ── 3. Install oh-my-zsh ─────────────────────────────────────────────────
  if [[ -d "${HOME}/.oh-my-zsh" ]]; then
    success "oh-my-zsh is already installed"
  else
    info "Installing oh-my-zsh ..."
    if ! command_exists zsh; then
      if command_exists apt-get; then
        apt-get install -y zsh
      elif command_exists brew; then
        brew install zsh
      elif command_exists dnf; then
        dnf install -y zsh
      elif command_exists yum; then
        yum install -y zsh
      elif command_exists apk; then
        apk add zsh
      elif command_exists pacman; then
        pacman -S --noconfirm zsh
      else
        error "zsh not found and no supported package manager available."
        exit 1
      fi
    fi
    RUNZSH=no CHSH=no \
      sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
    success "oh-my-zsh installed"
  fi

  # ── 4. Interactive storage-account setup ─────────────────────────────────
  if declare -F section >/dev/null 2>&1; then
    section "AZURE STORAGE" "Backup configuration" "blue"
  else
    info "--- Azure Blob Storage backup configuration ---"
  fi
  local storage_account container_name

  storage_account=$(ask "Azure Storage Account name")
  container_name=$(ask "Azure Blob Container name" "backups")

  {
    echo "AZURE_STORAGE_ACCOUNT=${storage_account}"
    echo "AZURE_STORAGE_CONTAINER=${container_name}"
  } >> "${ENV_FILE}"

  success "Storage config saved to ${ENV_FILE}"
  info "Upload command that will be used during backup:"
  if declare -F bullet_list >/dev/null 2>&1; then
    bullet_list \
      "az storage blob upload \\" \
      "--account-name ${storage_account} \\" \
      "--container-name ${container_name} \\" \
      "--name archive.zip \\" \
      "--file ${ARCHIVE_FILE}"
  else
    echo "  az storage blob upload \\"
    echo "    --account-name ${storage_account} \\"
    echo "    --container-name ${container_name} \\"
    echo "    --name archive.zip \\"
    echo "    --file ${ARCHIVE_FILE}"
  fi
}

# ---------------------------------------------------------------------------
# hybrid
# ---------------------------------------------------------------------------

cmd_hybrid() {
  if declare -F section >/dev/null 2>&1; then
    section "HYBRID" "Apigee Hybrid v1.16 setup" "cyan"
  else
    info "=== Apigee Hybrid v1.16 setup ==="
  fi

  # ── Documentation links ──────────────────────────────────────────────────
  info "Relevant documentation:"
  if declare -F bullet_list >/dev/null 2>&1; then
    bullet_list \
      "Before you begin: ${DOC_BEFORE_BEGIN}" \
      "Download charts: ${DOC_DOWNLOAD_CHARTS}" \
      "Install guide: ${DOC_INSTALL_HYBRID}"
  else
    echo "  Before you begin : ${DOC_BEFORE_BEGIN}"
    echo "  Download charts  : ${DOC_DOWNLOAD_CHARTS}"
    echo "  Install guide    : ${DOC_INSTALL_HYBRID}"
  fi

  # ── 1. Interactive environment variables ─────────────────────────────────
  if declare -F section >/dev/null 2>&1; then
    section "ENV" "Apigee Hybrid environment variables" "blue"
  else
    info "--- Apigee Hybrid environment variables ---"
  fi
  info "Values will be written to ${ENV_FILE}"

  # Load existing values if present
  if [[ -f "${ENV_FILE}" ]]; then
    # shellcheck source=/dev/null
    source "${ENV_FILE}"
  fi

  local project_id org_name org_display_name org_description \
        analytics_region runtime_type helm_charts_home \
        cluster_name cluster_region

  project_id=$(ask        "GCP Project ID"                           "${PROJECT_ID:-}")
  org_name=$(ask          "Apigee Organization name"                 "${ORG_NAME:-$project_id}")
  org_display_name=$(ask  "Apigee Organization display name"         "${ORG_DISPLAY_NAME:-$org_name}")
  org_description=$(ask   "Apigee Organization description"          "${ORGANIZATION_DESCRIPTION:-Apigee Hybrid organization}")
  analytics_region=$(ask  "Analytics region (e.g. europe-west1)"    "${ANALYTICS_REGION:-us-central1}")
  runtime_type=$(ask      "Runtime type"                             "${RUNTIMETYPE:-HYBRID}")
  cluster_name=$(ask      "Kubernetes cluster name"                  "${CLUSTER_NAME:-apigee-hybrid}")
  cluster_region=$(ask    "Kubernetes cluster region"                "${CLUSTER_REGION:-${analytics_region}}")
  helm_charts_home=$(ask  "Local Helm charts directory"              "${APIGEE_HELM_CHARTS_HOME:-${HOME}/apigee-hybrid/helm-charts}")

  # Preserve any existing Azure storage config before overwriting the file
  local azure_storage_account="${AZURE_STORAGE_ACCOUNT:-}"
  local azure_storage_container="${AZURE_STORAGE_CONTAINER:-}"

  # Persist to .env
  cat > "${ENV_FILE}" <<EOF
# Apigee Hybrid – environment variables
# Generated by cshell on $(date -u +"%Y-%m-%dT%H:%M:%SZ")

PROJECT_ID=${project_id}
ORG_NAME=${org_name}
ORG_DISPLAY_NAME=${org_display_name}
ORGANIZATION_DESCRIPTION=${org_description}
ANALYTICS_REGION=${analytics_region}
RUNTIMETYPE=${runtime_type}
CLUSTER_NAME=${cluster_name}
CLUSTER_REGION=${cluster_region}
APIGEE_HELM_CHARTS_HOME=${helm_charts_home}

# Helm chart coordinates
CHART_REPO=${CHART_REPO}
CHART_VERSION=${CHART_VERSION}
EOF

  # Re-append Azure storage config if it was saved previously
  if [[ -n "${azure_storage_account}" ]]; then
    {
      echo ""
      echo "# Azure Blob Storage (preserved from previous setup)"
      echo "AZURE_STORAGE_ACCOUNT=${azure_storage_account}"
      echo "AZURE_STORAGE_CONTAINER=${azure_storage_container}"
    } >> "${ENV_FILE}"
  fi

  success "Environment variables written to ${ENV_FILE}"
  echo    "Source them with:  source ${ENV_FILE}"
  echo ""

  # ── 2. Download Helm charts ───────────────────────────────────────────────
  if ! command_exists helm; then
    error "helm is not installed. Install Helm v3.14+ from https://helm.sh/docs/intro/install/"
    exit 1
  fi

  info "Downloading Apigee Hybrid Helm charts (version ${CHART_VERSION}) ..."
  mkdir -p "${helm_charts_home}"
  (
    cd "${helm_charts_home}"
    for chart in "${APIGEE_CHARTS[@]}"; do
      info "Pulling ${chart} ..."
      helm pull "${CHART_REPO}/${chart}" --version "${CHART_VERSION}" --untar
    done
  )
  success "Helm charts downloaded to ${helm_charts_home}"
}

# ---------------------------------------------------------------------------
# init – create Azure Storage Account and container
# ---------------------------------------------------------------------------

cmd_init() {
  if declare -F section >/dev/null 2>&1; then
    section "INIT" "Create Azure Storage Account resources" "cyan"
  else
    info "=== cshell init - create Azure Storage Account ==="
  fi

  if ! command_exists az; then
    error "Azure CLI (az) is not installed or not in PATH."
    exit 1
  fi

  # Load existing env values as defaults (if available)
  if [[ -f "${ENV_FILE}" ]]; then
    # shellcheck source=/dev/null
    source "${ENV_FILE}"
  fi

  local subscription resource_group location storage_account container_name sku allow_cross_tenant_replication

  subscription=$(ask    "Azure Subscription ID or name (leave blank to use current)" "${AZURE_SUBSCRIPTION:-}")
  resource_group=$(ask  "Resource group name"                                         "${AZURE_RESOURCE_GROUP:-rg-cshell}")
  location=$(ask        "Azure region (e.g. westeurope)"                              "${AZURE_LOCATION:-westeurope}")
  storage_account=$(ask "Storage Account name (3-24 lowercase letters/digits)"        "${AZURE_STORAGE_ACCOUNT:-}")
  container_name=$(ask  "Blob container name"                                         "${AZURE_STORAGE_CONTAINER:-backups}")
  sku=$(ask             "Storage SKU"                                                 "${AZURE_STORAGE_SKU:-Standard_LRS}")
  allow_cross_tenant_replication=$(ask "Allow cross-tenant replication? (true/false)" "${AZURE_STORAGE_ALLOW_CROSS_TENANT_REPLICATION:-false}")

  # ── Set subscription ────────────────────────────────────────────────────
  if [[ -n "${subscription}" ]]; then
    info "Setting active subscription to '${subscription}' ..."
    az account set --subscription "${subscription}"
    success "Subscription set"
  fi

  # ── Create resource group if it does not exist ───────────────────────────
  if az group show --name "${resource_group}" &>/dev/null; then
    success "Resource group '${resource_group}' already exists"
  else
    info "Creating resource group '${resource_group}' in '${location}' ..."
    az group create \
      --name "${resource_group}" \
      --location "${location}" \
      --output none
    success "Resource group '${resource_group}' created"
  fi

  # ── Create Storage Account if it does not exist ──────────────────────────
  if az storage account show \
       --name "${storage_account}" \
       --resource-group "${resource_group}" &>/dev/null; then
    success "Storage Account '${storage_account}' already exists"
  else
    info "Creating Storage Account '${storage_account}' (${sku}, allowCrossTenantReplication=${allow_cross_tenant_replication}) ..."
    az storage account create \
      --name "${storage_account}" \
      --resource-group "${resource_group}" \
      --location "${location}" \
      --sku "${sku}" \
      --kind StorageV2 \
      --allow-cross-tenant-replication "${allow_cross_tenant_replication}" \
      --output none
    success "Storage Account '${storage_account}' created"
  fi

  # ── Create Blob container if it does not exist ───────────────────────────
  if az storage container exists \
       --name "${container_name}" \
       --account-name "${storage_account}" \
       --auth-mode login \
       --query "exists" \
       --output tsv 2>/dev/null | grep -q "^true$"; then
    success "Blob container '${container_name}' already exists"
  else
    info "Creating blob container '${container_name}' ..."
    az storage container create \
      --name "${container_name}" \
      --account-name "${storage_account}" \
      --auth-mode login \
      --output none
    success "Blob container '${container_name}' created"
  fi

  # ── Persist config to env file (remove any previous cshell init block) ───
  if [[ -f "${ENV_FILE}" ]]; then
    # Strip previous block written by cshell init to avoid duplicate entries
    sed -i '/^# Azure Storage – written by cshell init/,/^AZURE_STORAGE_SKU=/d' "${ENV_FILE}"
  fi

  {
    echo ""
    echo "# Azure Storage – written by cshell init on $(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    echo "AZURE_SUBSCRIPTION=${subscription}"
    echo "AZURE_RESOURCE_GROUP=${resource_group}"
    echo "AZURE_LOCATION=${location}"
    echo "AZURE_STORAGE_ACCOUNT=${storage_account}"
    echo "AZURE_STORAGE_CONTAINER=${container_name}"
    echo "AZURE_STORAGE_SKU=${sku}"
    echo "AZURE_STORAGE_ALLOW_CROSS_TENANT_REPLICATION=${allow_cross_tenant_replication}"
  } >> "${ENV_FILE}"

  success "Configuration saved to ${ENV_FILE}"
  info  "Run 'cshell backup' to create and upload your first backup."
}

# ---------------------------------------------------------------------------
# backup
# ---------------------------------------------------------------------------

cmd_backup() {
  if declare -F section >/dev/null 2>&1; then
    section "BACKUP" "Backup home directory" "cyan"
  else
    info "=== Backup home directory ==="
  fi

  info "Creating archive: ${ARCHIVE_FILE}"
  (cd "${HOME}" && zip -r "${ARCHIVE_FILE}" . \
    --exclude ".cache/*" \
    --exclude ".config/google-cloud-sdk/logs/*" \
    --exclude "archive.zip")
  success "Backup created: ${ARCHIVE_FILE}"

  # Optional: upload to Azure Blob Storage
  if [[ -f "${ENV_FILE}" ]]; then
    # shellcheck source=/dev/null
    source "${ENV_FILE}"
  fi

  if [[ -n "${AZURE_STORAGE_ACCOUNT:-}" && -n "${AZURE_STORAGE_CONTAINER:-}" ]]; then
    info "Uploading archive to Azure Blob Storage ..."
    if upload_blob_with_fallback \
      "${AZURE_STORAGE_ACCOUNT}" \
      "${AZURE_STORAGE_CONTAINER}" \
      "archive.zip" \
      "${ARCHIVE_FILE}"; then
      success "Archive uploaded to Azure Blob Storage"
      info "  Account  : ${AZURE_STORAGE_ACCOUNT}"
      info "  Container: ${AZURE_STORAGE_CONTAINER}"
    else
      warn "Backup archive exists locally but upload failed."
      warn "Grant one role like 'Storage Blob Data Contributor' on the storage account,"
      warn "or set AZURE_STORAGE_ACCOUNT_KEY in ${ENV_FILE} for key-based fallback."
    fi
  else
    warn "No Azure storage config found. Skipping upload."
    warn "Run 'cshell setup' to configure Azure Blob Storage."
  fi
}

# ---------------------------------------------------------------------------
# restore
# ---------------------------------------------------------------------------

cmd_restore() {
  if declare -F section >/dev/null 2>&1; then
    section "RESTORE" "Restore home directory" "cyan"
  else
    info "=== Restore home directory ==="
  fi

  # Optionally download archive from Azure Blob Storage first
  if [[ -f "${ENV_FILE}" ]]; then
    # shellcheck source=/dev/null
    source "${ENV_FILE}"
  fi

  if [[ ! -f "${ARCHIVE_FILE}" ]]; then
    if [[ -n "${AZURE_STORAGE_ACCOUNT:-}" && -n "${AZURE_STORAGE_CONTAINER:-}" ]]; then
      info "archive.zip not found locally - downloading from Azure Blob Storage ..."
      if download_blob_with_fallback \
        "${AZURE_STORAGE_ACCOUNT}" \
        "${AZURE_STORAGE_CONTAINER}" \
        "archive.zip" \
        "${ARCHIVE_FILE}"; then
        success "archive.zip downloaded from Azure Blob Storage"
      else
        error "Could not download archive.zip from Azure Blob Storage."
        error "Grant blob data permissions or set AZURE_STORAGE_ACCOUNT_KEY in ${ENV_FILE}."
        exit 1
      fi
    else
      error "archive.zip not found at ${ARCHIVE_FILE} and no Azure storage config available."
      echo  "Place archive.zip in your home directory or run 'cshell setup' to configure Azure."
      exit 1
    fi
  fi

  info "Restoring from ${ARCHIVE_FILE} into ${HOME} ..."
  (cd "${HOME}" && unzip -o "${ARCHIVE_FILE}")
  success "Restore completed from ${ARCHIVE_FILE}"
}

# ---------------------------------------------------------------------------
# usage / main
# ---------------------------------------------------------------------------

usage() {
  cat <<EOF
Usage: ${SCRIPT_NAME} <command>

Commands:
  init     Create Azure Resource Group, Storage Account and Blob container
  setup    Install cshell, gcloud, oh-my-zsh and configure Azure Blob Storage
  hybrid   Download Apigee Hybrid Helm charts and set up environment variables
  backup   Backup home directory to archive.zip (and upload to Azure)
  restore  Restore home directory from archive.zip (download from Azure if needed)

Environment file: ${ENV_FILE}

Documentation:
  Apigee Hybrid before you begin : ${DOC_BEFORE_BEGIN}
  Apigee Hybrid download charts  : ${DOC_DOWNLOAD_CHARTS}
  Install guide                  : ${DOC_INSTALL_HYBRID}
EOF
}

case "${1:-}" in
  init)    cmd_init    ;;
  setup)   cmd_setup   ;;
  hybrid)  cmd_hybrid  ;;
  backup)  cmd_backup  ;;
  restore) cmd_restore ;;
  *)       usage; exit 1 ;;
esac
